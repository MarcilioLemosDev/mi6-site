{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/motos(/.*)?", "destination": "/consorcio-de-motos/", "permanent": true },
    { "source": "/carros(/.*)?", "destination": "/consorcio-de-carros/", "permanent": true },
    { "source": "/pesados(/.*)?", "destination": "/", "permanent": true },
    { "source": "/imoveis(/.*)?", "destination": "/consorcio-de-imoveis/", "permanent": true },
    { "source": "/servicos(/.*)?", "destination": "/", "permanent": true },
    { "source": "/eletro(/.*)?", "destination": "/", "permanent": true },
    { "source": "/sobre(/.*)?", "destination": "/", "permanent": true },
    { "source": "/blog(/.*)?", "destination": "/", "permanent": true },
    { "source": "/category(/.*)?", "destination": "/", "permanent": true },
    { "source": "/contato(/.*)?", "destination": "/#contato", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'sha256-xBLRIEPyEi4wjnXKU0OdZPHuoVrkUo4zJHMQ/u4unzA=' 'sha256-PWmyzaS+SZdxnr7Xr8LeQM4k1BBxoSjwX91qJwUJuz4=' 'sha256-XHyruQA0PAnCeVjCTzzGRuKgoJcRnyx8dteD71Pc/N4='; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
        }
      ]
    }
  ]
}
