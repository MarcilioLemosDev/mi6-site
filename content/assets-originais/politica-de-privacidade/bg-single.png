<script>
document.addEventListener('DOMContentLoaded', function() {
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
    const hamburger = document.querySelector('.hamburger');
    
    // Toggle do menu mobile
    if (mobileMenuBtn && mobileMenuOverlay) {
        mobileMenuBtn.addEventListener('click', function() {
            const isOpen = mobileMenuOverlay.classList.contains('active');
            
            mobileMenuOverlay.classList.toggle('active');
            hamburger.classList.toggle('active');
            document.body.classList.toggle('menu-open');
            
            // Atualizar atributos de acessibilidade
            mobileMenuBtn.setAttribute('aria-expanded', !isOpen);
            mobileMenuOverlay.setAttribute('aria-hidden', isOpen);
            
            // Focar no primeiro link do menu quando abrir
            if (!isOpen) {
                const firstLink = mobileMenuOverlay.querySelector('a');
                if (firstLink) {
                    setTimeout(() => firstLink.focus(), 100);
                }
            }
        });
        
        // Fechar menu ao clicar no overlay
        mobileMenuOverlay.addEventListener('click', function(e) {
            if (e.target === mobileMenuOverlay) {
                closeMobileMenu();
            }
        });
        
        // Função para fechar o menu mobile
        function closeMobileMenu() {
            mobileMenuOverlay.classList.remove('active');
            hamburger.classList.remove('active');
            document.body.classList.remove('menu-open');
            mobileMenuBtn.setAttribute('aria-expanded', 'false');
            mobileMenuOverlay.setAttribute('aria-hidden', 'true');
        }
    }
    
    // Toggle dos submenus mobile
    const dropdownToggles = document.querySelectorAll('.mobile-dropdown-toggle');
    dropdownToggles.forEach(function(toggle) {
        toggle.addEventListener('click', function(e) {
            e.preventDefault();
            
            const submenu = this.parentElement.querySelector('.mobile-sub-menu');
            const arrow = this.querySelector('.dropdown-arrow');
            
            if (submenu) {
                // Fechar outros submenus abertos
                dropdownToggles.forEach(function(otherToggle) {
                    if (otherToggle !== toggle) {
                        const otherSubmenu = otherToggle.parentElement.querySelector('.mobile-sub-menu');
                        const otherArrow = otherToggle.querySelector('.dropdown-arrow');
                        if (otherSubmenu) {
                            otherSubmenu.classList.remove('active');
                            otherToggle.classList.remove('active');
                            if (otherArrow) {
                                otherArrow.textContent = '+';
                            }
                        }
                    }
                });
                
                // Toggle do submenu atual
                submenu.classList.toggle('active');
                toggle.classList.toggle('active');
                
                if (arrow) {
                    arrow.textContent = submenu.classList.contains('active') ? '−' : '+';
                }
            }
        });
    });
    
    // Fechar menu ao redimensionar para desktop
    window.addEventListener('resize', function() {
        if (window.innerWidth > 991) {
            closeMobileMenu();
        }
    });
    
    // Fechar menu ao clicar em um link
    const mobileLinks = document.querySelectorAll('.mobile-nav-menu a:not(.mobile-dropdown-toggle)');
    mobileLinks.forEach(function(link) {
        link.addEventListener('click', function() {
            closeMobileMenu();
        });
    });
    
    // Fechar menu com tecla Escape
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && mobileMenuOverlay.classList.contains('active')) {
            closeMobileMenu();
            mobileMenuBtn.focus();
        }
    });
});
</script>

