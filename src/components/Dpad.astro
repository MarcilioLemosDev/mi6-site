---
// D-pad de toque (setas ↑↓←→). Cada botão emite data-btn para o controlador.
---

<div class="dpad no-select" role="group" aria-label="Controle direcional">
  <button class="pad up" data-btn="up" aria-label="Cima">▲</button>
  <button class="pad left" data-btn="left" aria-label="Esquerda">◀</button>
  <button class="pad center" aria-hidden="true"></button>
  <button class="pad right" data-btn="right" aria-label="Direita">▶</button>
  <button class="pad down" data-btn="down" aria-label="Baixo">▼</button>
</div>

<style>
  .dpad {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(3, 1fr);
    gap: 3px;
    width: 8.5rem;
    height: 8.5rem;
  }

  .pad {
    border: none;
    background: var(--btn);
    color: var(--shell);
    font-size: 0.7rem;
    border-radius: 6px;
    cursor: pointer;
    display: grid;
    place-items: center;
    box-shadow: 0 3px 0 #2c2c32;
    transition: transform 0.05s, box-shadow 0.05s;
    touch-action: none;
  }

  .pad:active {
    transform: translateY(2px);
    box-shadow: 0 1px 0 #2c2c32;
  }

  .up { grid-area: 1 / 2; }
  .left { grid-area: 2 / 1; }
  .center { grid-area: 2 / 2; background: var(--btn-face); box-shadow: none; cursor: default; }
  .right { grid-area: 2 / 3; }
  .down { grid-area: 3 / 2; }
</style>
