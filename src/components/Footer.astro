---
import { socials, credit } from '../data/links';

// Mapa de ícones (SVG inline) por rede.
const ICONS: Record<string, string> = {
  linkedin:
    'M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z',
};
---

<footer class="footer no-select">
  <a class="credito" href={credit.url} target="_blank" rel="noopener">{credit.label}</a>
  <div class="redes">
    {
      socials.map((s) => (
        <a class="social" href={s.url} target="_blank" rel="noopener" aria-label={s.label}>
          <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
            <path d={ICONS[s.id]} fill="currentColor" />
          </svg>
        </a>
      ))
    }
  </div>
</footer>

<style>
  .footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: -0.3rem;
    padding: 0 0.2rem;
  }

  /* Crédito clicável, centralizado no rodapé (mostra só o texto, o link fica atrás). */
  .credito {
    flex: 1;
    text-align: center;
    font-size: 0.34rem;
    line-height: 1.5;
    letter-spacing: 0.02em;
    color: var(--shell-shadow);
    text-decoration: none;
  }
  .credito:hover { color: #fff; }

  .redes {
    display: flex;
    gap: 0.5rem;
    flex: none;
  }

  .social {
    display: grid;
    place-items: center;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 7px;
    color: #fff;
    background: var(--btn);
    box-shadow: 0 2px 0 rgba(0, 0, 0, 0.35);
    transition: transform 0.08s, box-shadow 0.08s, background 0.15s;
  }

  .social:hover {
    background: var(--btn-face);
  }

  .social:active {
    transform: translateY(2px);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.35);
  }

  .social svg {
    width: 0.95rem;
    height: 0.95rem;
  }
</style>
