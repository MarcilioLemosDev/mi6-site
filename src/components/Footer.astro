---
import { socials, credit } from '../data/links';

// Mapa de ícones (SVG inline) por rede.
const ICONS: Record<string, string> = {
  linkedin:
    'M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z',
};
---

<footer class="footer no-select">
  <a class="credito" href={credit.url} target="_blank" rel="noopener">{credit.label}</a>
  <div class="redes">
    {
      socials.map((s) => (
        <a class="social" href={s.url} target="_blank" rel="noopener" aria-label={s.label}>
          <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
            <path d={ICONS[s.id]} fill="currentColor" />
          </svg>
        </a>
      ))
    }
  </div>
</footer>

<style>
  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 0.1rem;
    padding: 0.2rem 0.2rem 0;
  }

  /* Crédito clicável e discreto (o link abre o perfil no app do Instagram). */
  .credito {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-size: 0.72rem;
    line-height: 1.3;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .credito:hover { color: #fff; }

  .redes {
    display: flex;
    gap: 0.5rem;
    flex: none;
  }

  .social {
    display: grid;
    place-items: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 11px;
    color: #fff;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: transform 0.1s ease, background 0.15s ease, border-color 0.15s ease;
  }

  .social:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
  }

  .social:active {
    transform: scale(0.94);
  }

  .social svg {
    width: 1.05rem;
    height: 1.05rem;
  }
</style>

<script>
  // No mobile, o crédito tenta abrir o perfil no APP do Instagram
  // (deep link instagram://user?username=...), com fallback para o link
  // normal (https) se o app não abrir (não instalado, desktop, etc.).
  const link = document.querySelector<HTMLAnchorElement>('.credito');
  if (link) {
    link.addEventListener('click', (e) => {
      const web = link.href;
      const isMobile = /iphone|ipad|ipod|android/i.test(navigator.userAgent);
      if (!isMobile) return; // desktop: segue o comportamento normal

      let user = '';
      try {
        user = new URL(web).pathname.replace(/\//g, '');
      } catch {}
      if (!user) return;

      e.preventDefault();
      const app = 'instagram://user?username=' + user;
      // Se o app abrir, a página vai para segundo plano e cancelamos o fallback.
      const fallback = window.setTimeout(() => {
        window.location.href = web;
      }, 700);
      const cancel = () => window.clearTimeout(fallback);
      window.addEventListener('pagehide', cancel, { once: true });
      document.addEventListener(
        'visibilitychange',
        () => {
          if (document.hidden) cancel();
        },
        { once: true }
      );
      window.location.href = app;
    });
  }
</script>
