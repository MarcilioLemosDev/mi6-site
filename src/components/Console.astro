---
// Gamelink da MI6 reimaginado: um iPhone moderno (moldura de titânio, Dynamic
// Island, botões laterais) cuja TELA roda o "app" da MI6. A alma retrô fica
// preservada e contida numa "telinha antiga" (LCD pixelado) embutida no app; o
// resto (menu de links) é interface moderna. O jogo é jogado por toque/swipe na
// telinha (sem D-pad físico). Tema (navy/vermelho) via variáveis do global.css.
import '@fontsource-variable/inter';
import Screen from './Screen.astro';
import Menu from './Menu.astro';
import Footer from './Footer.astro';
import { type MenuLink } from '../data/links';

interface Props {
  links?: MenuLink[];
}
const { links } = Astro.props;
---

<div class="palco">
  <main class="fone no-select" aria-label="MI6 Consórcio Nacional">
    <!-- Botões físicos do aparelho (decorativos) -->
    <span class="btn-lat acao" aria-hidden="true"></span>
    <span class="btn-lat vol-cima" aria-hidden="true"></span>
    <span class="btn-lat vol-baixo" aria-hidden="true"></span>
    <span class="btn-lat power" aria-hidden="true"></span>

    <div class="tela">
      <!-- Status bar do iOS -->
      <div class="statusbar">
        <span class="hora">9:41</span>
        <span class="sinais" aria-hidden="true">
          <svg class="ic-sinal" viewBox="0 0 18 12"><rect x="0" y="8" width="3" height="4" rx="1"/><rect x="5" y="5" width="3" height="7" rx="1"/><rect x="10" y="2.5" width="3" height="9.5" rx="1"/><rect x="15" y="0" width="3" height="12" rx="1"/></svg>
          <svg class="ic-wifi" viewBox="0 0 16 12"><path d="M8 11.2 9.6 9.3a2.1 2.1 0 0 0-3.2 0L8 11.2Zm0-4.8a5 5 0 0 1 3.8 1.8l1.5-1.8a7.4 7.4 0 0 0-10.6 0l1.5 1.8A5 5 0 0 1 8 6.4Zm0-4.5c2.7 0 5.2 1 7.1 2.8L16.5 2A11.8 11.8 0 0 0 8 -1.5 11.8 11.8 0 0 0-.5 2L.9 3.9A10.1 10.1 0 0 1 8 1.9Z"/></svg>
          <span class="ic-bat"><span class="bat-nivel"></span></span>
        </span>
      </div>
      <!-- Dynamic Island -->
      <div class="ilha" aria-hidden="true"><span class="ilha-cam"></span></div>

      <!-- App da MI6 -->
      <div class="app">
        <header class="app-topo">
          <img class="app-logo" src="/imgs/logo-mi6-branco.png" alt="MI6 Consórcio Nacional" width="219" height="47" />
          <p class="app-linha">Primeiro passo</p>
        </header>

        <!-- Telinha antiga (LCD retrô) embutida no app moderno -->
        <section class="retro" aria-label="Mini-game retrô da MI6">
          <div class="retro-cabeca">
            <span class="retro-marca">Mini-game</span>
            <span class="retro-led" aria-hidden="true"></span>
          </div>
          <Screen />
          <p class="retro-dica">Toque para jogar · deslize para virar</p>
        </section>

        <Menu links={links} />
        <Footer />
      </div>

      <!-- Barra de gestos (home indicator) -->
      <div class="home-ind" aria-hidden="true"></div>
    </div>
  </main>
</div>

<style>
  .palco {
    width: 100%;
    min-height: 100dvh;
    display: grid;
    place-items: center;
    padding: 1.5rem 1rem;
  }

  /* ===== O aparelho: iPhone ===== */
  .fone {
    position: relative;
    height: min(88vh, 46rem);
    aspect-ratio: 96 / 199; /* proporção alta, tipo iPhone */
    border-radius: 14% / 6.8%;
    padding: 0.7rem;
    /* Moldura de titânio: metal escovado neutro (serve navy e vermelho). */
    background:
      linear-gradient(145deg, #3a3d44 0%, #16181d 18%, #2b2e34 40%, #101216 62%, #33363d 82%, #14161a 100%);
    box-shadow:
      0 2px 3px rgba(255, 255, 255, 0.35) inset,
      0 -2px 3px rgba(0, 0, 0, 0.6) inset,
      0 40px 80px -30px rgba(0, 0, 0, 0.75),
      0 12px 30px -12px rgba(0, 0, 0, 0.55);
  }
  /* Fina borda interna preta (vidro/bezel) */
  .fone::after {
    content: '';
    position: absolute;
    inset: 0.5rem;
    border-radius: 12.5% / 6.2%;
    box-shadow: 0 0 0 2px #050608, 0 0 0 3px rgba(255, 255, 255, 0.04);
    pointer-events: none;
    z-index: 3;
  }

  /* Botões laterais (nervuras de titânio) */
  .btn-lat {
    position: absolute;
    background: linear-gradient(90deg, #101216, #3a3d44 45%, #202329);
    z-index: 0;
    border-radius: 2px;
  }
  .btn-lat.acao { left: -3px; top: 20%; width: 3px; height: 3.2%; border-radius: 2px 0 0 2px; }
  .btn-lat.vol-cima { left: -3px; top: 27%; width: 3px; height: 6.5%; border-radius: 2px 0 0 2px; }
  .btn-lat.vol-baixo { left: -3px; top: 35.5%; width: 3px; height: 6.5%; border-radius: 2px 0 0 2px; }
  .btn-lat.power { right: -3px; top: 26%; width: 3px; height: 9%; border-radius: 0 2px 2px 0; }

  /* ===== A tela ===== */
  .tela {
    position: relative;
    height: 100%;
    width: 100%;
    border-radius: 11.5% / 5.6%;
    overflow: hidden;
    background:
      radial-gradient(125% 80% at 50% -12%, color-mix(in srgb, var(--shell) 42%, #0a0c11), #0a0c11 62%);
    display: flex;
    flex-direction: column;
    z-index: 1;
  }

  .statusbar {
    flex: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.55rem 1.5rem 0.2rem;
    height: 2.7rem;
    color: #fff;
    font-family: 'Inter Variable', system-ui, sans-serif;
  }
  .hora { font-size: 0.82rem; font-weight: 700; letter-spacing: 0.02em; }
  .sinais { display: inline-flex; align-items: center; gap: 0.35rem; }
  .ic-sinal { width: 1.05rem; height: 0.72rem; fill: #fff; }
  .ic-wifi { width: 1rem; height: 0.72rem; fill: #fff; }
  .ic-bat {
    width: 1.5rem; height: 0.72rem; border-radius: 3px;
    border: 1px solid rgba(255, 255, 255, 0.55);
    position: relative; display: inline-block; padding: 1.5px;
  }
  .ic-bat::after {
    content: ''; position: absolute; right: -3px; top: 50%; transform: translateY(-50%);
    width: 2px; height: 40%; border-radius: 0 2px 2px 0; background: rgba(255, 255, 255, 0.55);
  }
  .bat-nivel { display: block; width: 78%; height: 100%; border-radius: 1.5px; background: #fff; }

  .ilha {
    position: absolute;
    top: 0.55rem;
    left: 50%;
    transform: translateX(-50%);
    width: 34%;
    height: 1.65rem;
    background: #000;
    border-radius: 999px;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 0.5rem;
  }
  .ilha-cam {
    width: 0.5rem; height: 0.5rem; border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #1c2740, #05070d 70%);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.06);
  }

  /* App: conteúdo rolável dentro da tela (como um app real) */
  .app {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0.4rem 1.15rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
  }
  .app::-webkit-scrollbar { display: none; }

  .app-topo { text-align: center; padding-top: 0.2rem; }
  .app-logo { height: 1.35rem; width: auto; display: inline-block; }
  .app-linha {
    margin: 0.5rem 0 0;
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    padding-left: 0.35em;
  }

  /* ===== Módulo do mini-game: card MODERNO que emoldura a telinha retrô.
     Só o LCD quadrado (dentro) é retrô; a moldura e os textos são modernos. */
  .retro {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 22px;
    padding: 0.85rem 0.85rem 0.7rem;
    box-shadow: 0 12px 28px -18px rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(6px);
  }
  .retro-cabeca {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 0.2rem 0.6rem;
  }
  .retro-marca {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }
  .retro-led {
    width: 7px; height: 7px; border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, var(--led-hi, #ff7d90), var(--accent));
    box-shadow: 0 0 6px var(--accent);
    animation: led-pulse 2.4s ease-in-out infinite;
  }
  .retro-dica {
    margin: 0.55rem 0 0;
    text-align: center;
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-size: 0.55rem;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.38);
  }
  @keyframes led-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
  @media (prefers-reduced-motion: reduce) { .retro-led { animation: none; } }

  .home-ind {
    position: absolute;
    bottom: 0.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: 34%;
    height: 5px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.85);
    z-index: 5;
  }

  /* Entrada suave do aparelho */
  @media (prefers-reduced-motion: no-preference) {
    .fone { animation: fone-entra 0.7s cubic-bezier(0.22, 1, 0.36, 1) both; }
    @keyframes fone-entra {
      from { opacity: 0; transform: translateY(18px) scale(0.97); }
      to { opacity: 1; transform: none; }
    }
  }
</style>
