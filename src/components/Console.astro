---
// O aparelho inteiro: telinha em cima; metade de baixo dividida em
// menu (esquerda) + D-pad (direita), como um handheld antigo.
import Screen from './Screen.astro';
import Menu from './Menu.astro';
import Dpad from './Dpad.astro';
import Footer from './Footer.astro';
---

<main class="console no-select">
  <div class="topbar">
    <span class="led" aria-hidden="true"></span>
    <img class="brand-logo" src="/imgs/logo-mi6-branco.png" alt="MI6 Consórcio Nacional" width="219" height="47" />
    <span class="power" aria-hidden="true">POWER</span>
  </div>

  <Screen />

  <div class="controls">
    <Menu />
    <Dpad />
  </div>

  <Footer />
</main>

<style>
  .console {
    width: min(92vw, 22rem);
    background: linear-gradient(160deg, var(--shell), var(--shell-dark));
    border-radius: 18px 18px 40px 18px;
    padding: 1.1rem;
    box-shadow:
      0 20px 40px rgba(0, 0, 0, 0.5),
      inset 0 2px 2px rgba(255, 255, 255, 0.4);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0 0.2rem;
  }

  .brand-logo {
    height: 1.15rem;
    width: auto;
    display: block;
  }

  .led {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #ff7d90, var(--accent));
    box-shadow: 0 0 6px var(--accent), inset 0 0 2px rgba(255, 255, 255, 0.6);
    animation: led-pulse 2.4s ease-in-out infinite;
  }

  .power {
    font-size: 0.32rem;
    color: var(--shell-shadow);
    letter-spacing: 0.12em;
    opacity: 0.7;
  }

  @keyframes led-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.55; }
  }

  @media (prefers-reduced-motion: reduce) {
    .led { animation: none; }
  }

  .controls {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.9rem;
    align-items: center;
  }
</style>
