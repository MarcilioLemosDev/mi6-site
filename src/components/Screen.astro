---
// A "telinha" LCD onde o Snake roda. Canvas quadrado + moldura escura.
---

<div class="screen no-select">
  <div class="lcd" id="lcd">
    <canvas id="game" width="160" height="160" aria-label="Jogo da cobrinha"></canvas>
    <div class="hud">
      <span class="hi" id="hi">HI 0000</span>
      <span class="score" id="score">0000</span>
    </div>
  </div>
</div>

<style>
  .screen {
    background: var(--shell-dark);
    padding: 0.9rem;
    border-radius: 10px;
    box-shadow:
      inset 0 2px 4px rgba(255, 255, 255, 0.3),
      inset 0 -3px 6px rgba(0, 0, 0, 0.35);
  }

  .lcd {
    position: relative;
    aspect-ratio: 1 / 1;
    width: 100%;
    background: var(--lcd-bg);
    border: 4px solid var(--lcd-ink);
    border-radius: 4px;
    overflow: hidden;
    box-shadow: inset 0 0 12px rgba(6, 48, 73, 0.4);
    touch-action: none; /* permite swipe sem rolar a página */
  }

  canvas {
    display: block;
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
    position: relative;
    z-index: 1;
  }

  /* Scanlines horizontais (efeito CRT) */
  .lcd::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.08) 0,
      rgba(0, 0, 0, 0.08) 1px,
      transparent 1px,
      transparent 3px
    );
  }

  /* Vinheta suave nos cantos */
  .lcd::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 58%, rgba(0, 0, 0, 0.16) 100%);
  }

  .hud {
    position: absolute;
    top: 5px;
    left: 7px;
    right: 7px;
    z-index: 3;
    display: flex;
    justify-content: space-between;
    font-size: 0.4rem;
    color: var(--lcd-ink);
    letter-spacing: 0.05em;
    pointer-events: none;
  }
</style>
