---
import { links as linksPadrao, type MenuLink } from '../data/links';

interface Props {
  links?: MenuLink[];
}
// Sem prop, usa os links da matriz (comportamento preservado).
const { links = linksPadrao } = Astro.props;
---

<nav class="menu" aria-label="Menu de links">
  <ul>
    {
      links.map((link, i) => (
        <li>
          {link.locked || !link.url ? (
            <span class="item locked" data-id={link.id} aria-disabled="true">
              <span class="item-txt">
                <span class="label">{link.label}</span>
                {link.sublabel && <span class="sub">{link.sublabel}</span>}
              </span>
              <svg class="marca-fim cadeado" viewBox="0 0 24 24" aria-hidden="true">
                <rect x="5" y="11" width="14" height="9" rx="2" />
                <path d="M8 11V8a4 4 0 0 1 8 0v3" />
              </svg>
            </span>
          ) : (
            <a
              class="item"
              href={link.url}
              target="_blank"
              rel="noopener"
              data-id={link.id}
              data-index={i}
            >
              <span class="item-txt">
                <span class="label">{link.label}</span>
                {link.sublabel && <span class="sub">{link.sublabel}</span>}
              </span>
              <svg class="marca-fim chevron" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M9 6l6 6-6 6" />
              </svg>
            </a>
          )}
        </li>
      ))
    }
  </ul>

  <!-- Mãozinha guia: cicla pelos botões ativos dando um "toque", como no site.
       Ajuda quem tem menos familiaridade a ver onde clicar. Some ao primeiro uso. -->
  <span class="menu-mao" aria-hidden="true">
    <span class="menu-toque"></span>
    <svg class="menu-cur" viewBox="0 0 24 24"><path d="M9 12.5V6a1.6 1.6 0 0 1 3.2 0v4.6m0-1.5a1.6 1.6 0 0 1 3.2 0v1.9m0-1.3a1.6 1.6 0 0 1 3.2 0v3.6a5.6 5.6 0 0 1-5.6 5.6h-1.6a4.6 4.6 0 0 1-3.5-1.6l-3-3.6a1.5 1.5 0 0 1 2.2-2L9 14z"/></svg>
  </span>
</nav>

<style>
  .menu {
    position: relative;
  }
  .menu ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin: 0;
    padding: 0;
  }

  /* Linha moderna (estilo iOS): card de vidro sobre o fundo escuro do app. */
  .item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 15px;
    color: #fff;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
    transition: background 0.18s ease, border-color 0.18s ease, transform 0.12s ease;
  }
  .item-txt { display: flex; flex-direction: column; gap: 0.12rem; min-width: 0; }
  .label {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .sub {
    font-family: 'Inter Variable', system-ui, sans-serif;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .marca-fim { width: 1.15rem; height: 1.15rem; flex: none; }
  .chevron {
    fill: none;
    stroke: var(--accent);
    stroke-width: 2.4;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform 0.18s ease;
  }
  .cadeado {
    fill: none;
    stroke: rgba(255, 255, 255, 0.45);
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* Hover/toque: destaca com a cor de ação e desliza o chevron. */
  @media (hover: hover) {
    .item:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    }
    .item:hover .chevron { transform: translateX(3px); }
  }
  .item:active { transform: scale(0.985); }
  .item:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .item.locked {
    opacity: 0.55;
    cursor: not-allowed;
  }

  /* Mãozinha guia */
  .menu-mao {
    position: absolute;
    left: 0;
    top: 0;
    width: 1.6rem;
    height: 1.6rem;
    z-index: 6;
    pointer-events: none;
    opacity: 0;
    transform: translate(0, 0);
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
  }
  .menu-mao.mostrar { opacity: 1; }
  .menu-cur {
    width: 100%;
    height: 100%;
    fill: var(--accent);
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.6));
  }
  .menu-toque {
    position: absolute;
    left: 0.66rem;
    top: 0.46rem;
    width: 1.6rem;
    height: 1.6rem;
    margin: -0.8rem 0 0 -0.8rem;
    border-radius: 50%;
    border: 2px solid var(--accent);
    transform: scale(0);
    opacity: 0;
  }
  .menu-mao.tocando .menu-cur { animation: maoPressao 0.9s ease; }
  .menu-mao.tocando .menu-toque { animation: maoRipple 0.9s ease; }
  @keyframes maoPressao {
    0%, 100% { transform: translate(0, 0); }
    35% { transform: translate(-1px, 3px); }
  }
  @keyframes maoRipple {
    0% { transform: scale(0); opacity: 0; }
    30% { transform: scale(0.5); opacity: 0.85; }
    100% { transform: scale(1.6); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .menu-mao { display: none; }
  }
</style>

<script>
  // Mãozinha guia: percorre os botões ativos (links reais), posicionando-se
  // na borda direita de cada um e dando um "toque" (anel), em looping. Some na
  // primeira interação e respeita "prefers-reduced-motion".
  const menu = document.querySelector<HTMLElement>('.menu');
  const mao = menu?.querySelector<HTMLElement>('.menu-mao') ?? null;
  const alvos = menu ? Array.from(menu.querySelectorAll<HTMLElement>('a.item')) : [];
  const reduz = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (menu && mao && alvos.length && !reduz) {
    let i = 0;
    let parado = false;
    let timer = 0;

    const posiciona = (el: HTMLElement) => {
      const mr = menu.getBoundingClientRect();
      const r = el.getBoundingClientRect();
      const x = r.right - mr.left - 30;
      const y = r.top - mr.top + r.height / 2 - 8;
      mao.style.transform = `translate(${x}px, ${y}px)`;
    };

    const ciclo = () => {
      if (parado) return;
      const el = alvos[i % alvos.length];
      posiciona(el);
      mao.classList.add('mostrar');
      mao.classList.remove('tocando');
      void mao.offsetWidth; // reinicia a animação do toque
      window.setTimeout(() => {
        if (!parado) mao.classList.add('tocando');
      }, 480);
      i += 1;
      timer = window.setTimeout(ciclo, 2000);
    };

    posiciona(alvos[0]);
    timer = window.setTimeout(ciclo, 800);

    const parar = () => {
      parado = true;
      window.clearTimeout(timer);
      mao.classList.remove('mostrar', 'tocando');
    };
    menu.addEventListener('pointerdown', parar, { once: true });
    window.addEventListener('resize', () => {
      if (!parado) posiciona(alvos[(i - 1 + alvos.length) % alvos.length]);
    });
  }
</script>
