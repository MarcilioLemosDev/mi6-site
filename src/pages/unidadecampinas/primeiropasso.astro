---
import Layout from '../../layouts/Layout.astro';
import Console from '../../components/Console.astro';
import { linksCampinas } from '../../data/links';
import '../../styles/global.css';
---

<Layout
  tema="campinas"
  title="MI6 Consórcio Nacional | Unidade Campinas"
  description="Links da unidade Campinas da MI6: acesse o site, simule seu consórcio e fale com a gente."
>
  <Console links={linksCampinas} />
</Layout>

<script>
  import { createArcade } from '../../scripts/arcade';
  import { initController, type Controller } from '../../scripts/controller';

  const canvas = document.getElementById('game') as HTMLCanvasElement | null;
  const lcd = document.getElementById('lcd');
  const scoreEl = document.getElementById('score');
  const hiEl = document.getElementById('hi');

  if (canvas) {
    let controller: Controller | null = null;

    const arcade = createArcade({
      canvas,
      scoreEl,
      hiEl,
      getHeld: () => controller?.held ?? new Set(),
    });

    controller = initController({
      swipeTarget: lcd,
      onPress: (button) => arcade.press(button),
    });
  }
</script>
