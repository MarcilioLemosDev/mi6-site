  }
  .lente {
    position: relative;
    width: clamp(16rem, 26vw, 23rem);
    aspect-ratio: 1;
    margin: 0;
    border-radius: 50%;
    overflow: hidden;
  }
  .lente img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    transform: scale(1.08);
    filter: grayscale(1) brightness(0.92) contrast(1.05);
  }
  .lente::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(80% 80% at 35% 25%, rgba(1, 33, 105, 0.18), rgba(1, 19, 58, 0.72));
    mix-blend-mode: multiply;
  }
  .lente-anel {
    position: absolute;
    inset: -7%;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 50%;
  }
  .lente-anel-dash {
    position: absolute;
    inset: -13%;
    border: 1px dashed rgba(255, 255, 255, 0.18);
    border-radius: 50%;
  }
  .lente-tick {
    position: absolute;
    top: -16%;
    left: 50%;
    width: 1px;
    height: 5%;
    background: var(--vermelho);
  }

  .ticket {
    border: 1px solid var(--linha);
    border-left: 3px solid var(--vermelho);
    background: rgba(1, 19, 58, 0.72);
    backdrop-filter: blur(4px);
    padding: 1rem 1.25rem;
    max-width: 17rem;
    transition: transform 0.3s ease, border-color 0.3s ease, background 0.3s ease;
  }
  .ticket:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.4);
    background: rgba(1, 19, 58, 0.9);
  }
  .ticket-rotulo {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.66rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gelo);
    margin: 0 0 0.4rem;
  }
  .ticket-valor {
    margin: 0 0 0.6rem;
    font-size: 0.95rem;
  }
  .ticket-valor strong {
    font-family: 'Instrument Serif', Georgia, serif;
    font-weight: 400;
    font-size: 1.35rem;
  }
  .ticket-dia {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin: -0.35rem 0 0.65rem;
  }
  .ticket a {
    color: var(--branco);
    font-size: 0.88rem;
    font-weight: 600;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2.2rem;
    left: 2.5rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
    animation: pulsar 2.4s ease-in-out infinite;
  }
  @keyframes pulsar {
    50% {
      opacity: 0.35;
      transform: translateY(4px);
    }
  }

  /* Credibilidade: ABAC (filiada) e BACEN em texto, logo após o hero */
  .credibilidade {
    background: var(--papel);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.25rem 2.5rem;
    padding: 1.5rem 2.5rem;
  }
  .cred-abac {
    display: flex;
    align-items: center;
    gap: 1.1rem;
  }
  .cred-abac img {
    height: 2.3rem;
    width: auto;
    flex: none;
  }
  .cred-abac p {
    margin: 0;
    color: var(--tinta-suave);
    font-size: 0.85rem;
    max-width: 19rem;
    line-height: 1.4;
  }
  .cred-divisa {
    width: 1px;
    height: 2.4rem;
    background: rgba(1, 33, 105, 0.22);
  }
  .cred-bacen p {
    margin: 0;
  }
  .cred-frase {
    color: var(--navy);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .cred-oficio {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--tinta-suave);
    margin-top: 0.25rem !important;
  }

  /* Marquee */
  .marquee {
    overflow: hidden;
    border-top: 1px solid var(--linha);
    border-bottom: 1px solid var(--linha);
    background: var(--navy-escuro);
    padding: 0.7rem 0;
  }
  .marquee-faixa {
    display: flex;
    white-space: nowrap;
    width: max-content;
    animation: rolar 36s linear infinite;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gelo);
  }
  @keyframes rolar {
    to {
      transform: translateX(-50%);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-faixa,
    .hero-scroll,
    .lente-anel-dash {
      animation: none;
    }
  }

  /* Seções claras: o respiro humano entre os blocos navy */
  .claro {
    background: var(--papel);
    color: var(--tinta);
    padding: 7.5rem 2.5rem;
  }
  .claro h2,
  .claro h3 {
    color: var(--navy);
  }
  .claro .indice {
    color: #8a90a0;
  }
  .claro .apoio {
    color: var(--tinta-suave);
    margin: -1rem 0 3rem;
    max-width: 36rem;
  }
  .statement {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: clamp(1.8rem, 3.8vw, 3.1rem);
    line-height: 1.22;
    max-width: 30ch;
    margin: 0;
    color: var(--navy);
  }
  .statement em {
    color: var(--vermelho);
  }

  .vantagens {
    margin-top: 5rem;
  }
  .vantagens-lista {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem 2.5rem;
  }
  .vantagens-lista li {
    border-top: 1px solid var(--linha-clara);
    padding-top: 1.4rem;
    transform: translateY(calc(var(--desloca) * 1.75rem));
  }
  .vantagens-lista .num {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    color: var(--vermelho);
  }
  .vantagens-lista h3 {
    font-size: 1.65rem;
    margin: 0.7rem 0 0.5rem;
  }
  .vantagens-lista p {
    margin: 0;
    color: var(--tinta-suave);
    font-size: 0.97rem;
  }

  /* Galeria horizontal */
  .galeria {
    background: var(--navy-escuro);
    border-top: 1px solid var(--linha);
  }
  .galeria-pin {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding: 5rem 0 3.5rem;
    position: relative;
  }
  .galeria-cabeca {
    padding: 0 2.5rem;
    max-width: 70rem;
    margin: 0 auto 3rem;
    width: 100%;
  }
  .galeria-apoio {
    color: var(--gelo);
    max-width: 38rem;
    margin: 0;
  }
  .galeria-track {
    display: flex;
    gap: 2rem;
    padding: 0 2.5rem;
    width: max-content;
  }
  .galeria-dica {
    position: absolute;
    bottom: 1.6rem;
    right: 2.5rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.66rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
  }
  .painel {
    width: clamp(17rem, 26vw, 24rem);
    border: 1px solid var(--linha);
    padding: 1.25rem 1.25rem 1.5rem;
    background: rgba(255, 255, 255, 0.02);
    position: relative;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .painel:hover {
    border-color: rgba(255, 255, 255, 0.45);
    transform: translateY(-6px);
  }
  .painel-foto {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    margin-bottom: 1.1rem;
  }
  .painel-foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.95) contrast(1.03);
    transition: filter 0.55s ease, transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .painel-foto::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(1, 33, 105, 0.5), rgba(1, 19, 58, 0.68));
    mix-blend-mode: multiply;
    transition: opacity 0.55s ease;
  }
  .painel:hover .painel-foto img {
    filter: none;
    transform: scale(1.05);
  }
  .painel:hover .painel-foto::after {
    opacity: 0.12;
  }
  .painel-num {
    position: absolute;
    top: 0.4rem;
    right: 0.9rem;
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 3.2rem;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.35);
    margin: 0;
    pointer-events: none;
  }
  .painel h3 {
    font-size: 1.55rem;
    margin: 0 0 1rem;
  }
  .painel a {
    color: var(--branco);
    font-size: 0.9rem;
    font-weight: 600;
  }

  /* Método (claro) */
  .metodo-lista {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }
  .metodo-fio {
    position: absolute;
    left: -1.5rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: rgba(1, 33, 105, 0.14);
  }
  .metodo-fio i {
    position: absolute;
    inset: 0;
    background: var(--vermelho);
    transform-origin: top center;
    display: block;
  }
  .metodo-convite {
    margin: 2.25rem 0 0;
    font-size: 1.05rem;
    color: var(--tinta-suave);
  }
  .metodo-convite a {
    color: var(--navy);
    font-weight: 700;
  }
  .metodo-lista li {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 2rem;
    padding: 1.7rem 0;
    border-top: 1px solid var(--linha-clara);
    align-items: baseline;
  }
  .metodo-num {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 2.6rem;
    color: transparent;
    -webkit-text-stroke: 1px rgba(1, 33, 105, 0.55);
  }
  .metodo-lista p {
    margin: 0;
    font-size: 1.12rem;
    max-width: 44rem;
    color: var(--tinta);
  }

  /* Números */
  .numeros {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 1px solid var(--linha);
    border-bottom: 1px solid var(--linha);
    background: var(--navy-fundo);
    position: relative;
    overflow: hidden;
  }
  .seis-marca {
    position: absolute;
    right: -1.5rem;
    top: 50%;
    transform: translateY(-50%);
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 22rem;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.09);
    pointer-events: none;
    user-select: none;
  }
  .numeros-grande {
    padding: 4.5rem 2.5rem;
    text-align: center;
  }
  .numeros-grande + .numeros-grande {
    border-left: 1px solid var(--linha);
  }
  .numeros-valor {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: clamp(3.4rem, 8vw, 6.5rem);
    line-height: 1;
    margin: 0 0 1rem;
    font-variant-numeric: tabular-nums;
  }
  .numeros-sufixo {
    display: inline-block;
    font-size: 0.32em;
    margin-left: 0.4em;
    font-style: italic;
    color: var(--branco);
    border-bottom: 3px solid var(--vermelho);
    padding-bottom: 0.1em;
    transform: translateY(-0.35em);
  }
  .numeros-legenda {
    color: var(--gelo);
    margin: 0 auto;
    max-width: 24rem;
    font-size: 0.95rem;
  }
  .numeros-legenda small {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.5);
  }

  /* Diferenciais e FAQ (claro) */
  .diferenciais-lista {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .diferenciais-lista li {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 2fr);
    gap: 2rem;
    border-top: 1px solid var(--linha-clara);
    padding: 1.6rem 0;
  }
  .diferenciais-lista h3 {
    font-size: 1.6rem;
  }
  .diferenciais-lista p {
    margin: 0;
    color: var(--tinta-suave);
  }
  .documentos {
    margin: 2.25rem 0 0;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: var(--tinta-suave);
  }
  .documentos a {
    color: var(--navy);
  }

  .faq {
    margin-top: 6rem;
  }
  .faq-lista details {
    border-top: 1px solid var(--linha-clara);
  }
  .faq-lista details:last-child {
    border-bottom: 1px solid var(--linha-clara);
  }
  .faq-lista summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.35rem 0;
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 1.45rem;
    color: var(--navy);
  }
  .faq-lista summary::-webkit-details-marker {
    display: none;
  }
  .faq-sinal {
    flex: none;
    width: 0.9rem;
    height: 0.9rem;
    position: relative;
  }
  .faq-sinal::before,
  .faq-sinal::after {
    content: '';
    position: absolute;
    inset: 50% 0 auto;
    height: 1px;
    background: var(--vermelho);
    transition: transform 0.3s ease;
  }
  .faq-sinal::after {
    transform: rotate(90deg);
  }
  details[open] .faq-sinal::after {
    transform: rotate(0deg);
  }
  .faq-lista details p {
    margin: 0;
    padding: 0 0 1.6rem;
    color: var(--tinta-suave);
    max-width: 52rem;
  }
  @supports (interpolate-size: allow-keywords) {
    .faq-lista details::details-content {
      height: 0;
      overflow: clip;
      transition: height 0.4s ease, content-visibility 0.4s allow-discrete;
    }
    .faq-lista details[open]::details-content {
      height: auto;
    }
  }

  /* Contato */
  .contato {
    position: relative;
    overflow: hidden;
    background: var(--vermelho);
    color: var(--branco);
    padding: 6rem 2.5rem;
  }
  .contato-geo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .contato > :not(.contato-geo) {
    position: relative;
  }
  .sim-grade {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    gap: 3.5rem;
    max-width: 72rem;
    margin: 0 auto;
    align-items: start;
  }
  .contato h2 {
    font-size: clamp(2rem, 4.2vw, 3.4rem);
    margin: 0 0 1.25rem;
  }
  .sim-texto > p {
    max-width: 30rem;
    margin: 0 0 1.75rem;
    color: rgba(255, 255, 255, 0.88);
  }

  /* Cartão do simulador: a conta inteira, em papel sobre o vermelho */
  .sim-card {
    background: var(--papel);
    color: var(--tinta);
    border-top: 4px solid var(--navy);
    padding: 1.9rem;
    margin: 0;
    box-shadow: 0 34px 64px -32px rgba(1, 19, 58, 0.6);
  }
  .sim-passo {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--tinta-suave);
    margin: 0 0 0.8rem;
  }
  .sim-card .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .sim-card .chips button {
    font: inherit;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.45rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(1, 33, 105, 0.32);
    background: var(--branco);
    color: var(--navy);
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .sim-card .chips button:hover {
    border-color: var(--navy);
  }
  .sim-card .chips button[aria-pressed='true'] {
    background: var(--navy);
    border-color: var(--navy);
    color: var(--branco);
  }
  .sim-credito {
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
    margin: 0.25rem 0 0.4rem;
    color: var(--navy);
  }
  .sim-moeda {
    font-weight: 600;
    color: var(--tinta-suave);
  }
  .sim-credito output {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: clamp(2.6rem, 4vw, 3.4rem);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .sim-card input[type='range'] {
    width: 100%;
    appearance: none;
    height: 4px;
    border-radius: 999px;
    background: rgba(1, 33, 105, 0.18);
    outline-offset: 4px;
    margin: 0.5rem 0 0.3rem;
  }
  .sim-card input[type='range']::-webkit-slider-thumb {
    appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--vermelho);
    border: 3px solid var(--papel);
    box-shadow: 0 0 0 1px var(--vermelho);
    cursor: grab;
  }
  .sim-card input[type='range']::-moz-range-thumb {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--vermelho);
    border: 3px solid var(--papel);
    box-shadow: 0 0 0 1px var(--vermelho);
    cursor: grab;
  }
  .sim-extremos {
    display: flex;
    justify-content: space-between;
    font-size: 0.72rem;
    color: var(--tinta-suave);
    margin-bottom: 1.4rem;
  }
  .sim-conta {
    margin: 0 0 1.5rem;
  }
  .sim-conta div {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.55rem 0;
    border-bottom: 1px dotted rgba(1, 33, 105, 0.28);
  }
  .sim-conta dt {
    color: var(--tinta-suave);
    font-size: 0.88rem;
  }
  .sim-conta dd {
    margin: 0;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
  }
  .sim-parcela dt {
    color: var(--navy);
    font-weight: 700;
  }
  .sim-parcela dd {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 1.55rem;
    font-weight: 400;
    color: var(--navy);
  }
  .sim-assembleia {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--tinta-suave);
    margin: 0 0 1.1rem;
  }
  .sim-cta {
    display: block;
    width: 100%;
    border: 0;
    cursor: pointer;
    text-align: center;
    font: inherit;
    font-weight: 600;
  }
  .sim-cta[disabled] {
    opacity: 0.85;
    cursor: default;
  }
  .sim-cta-sec {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    margin-top: 0.6rem;
    padding: 0.8rem 1.5rem;
    border-radius: 999px;
    border: 1.5px solid rgba(1, 33, 105, 0.4);
    background: none;
    color: var(--navy);
    font: inherit;
    font-weight: 600;
    font-size: 0.92rem;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .sim-cta-sec:hover {
    background: var(--navy);
    color: var(--papel);
    border-color: var(--navy);
  }
  .sim-cta-sec svg {
    width: 1.05rem;
    height: 1.05rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
    flex: none;
  }
  .sim-cta-sec[disabled] {
    opacity: 0.7;
    cursor: default;
  }
  .sim-nota {
    font-size: 0.75rem;
    color: var(--tinta-suave);
    margin: 0.9rem 0 0;
    line-height: 1.5;
  }
  .sim-aguarde p {
    color: var(--tinta-suave);
    margin: 0 0 1.25rem;
  }
  .sim-aguarde-titulo {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 1.6rem;
    color: var(--navy) !important;
    margin: 0.25rem 0 0.6rem !important;
  }
  .cta-inverso {
    background: var(--branco);
    color: var(--vermelho);
  }
  .cta-inverso:hover {
    background: var(--navy-escuro);
    color: var(--branco);
  }
  .contato-acoes {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .contato-alt {
    font-size: 0.95rem;
  }
  .contato-garantias {
    list-style: none;
    margin: 0 0 1.75rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.1rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
