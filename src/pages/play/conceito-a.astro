---
import '@fontsource/instrument-serif';
import '@fontsource/instrument-serif/400-italic.css';
import '@fontsource-variable/public-sans';
import '@fontsource/ibm-plex-mono';
import '@fontsource/ibm-plex-mono/500.css';
import dados from '../../dados/grupos.json';
import marca from '../../dados/mi6-traco.json';

// CONCEITO A, DOSSIÊ (v2.1)
// Refino pós-feedback: mantém a modernidade navy cinematográfica e ganha a
// humanização do conceito B. Foto humana em duotone dentro de uma lente
// circular no hero, ritmo claro/escuro entre seções, fotos que ganham cor
// ao toque. Texto: o do site atual, com ajuste fino.

const segmentos = [
  {
    n: '01',
    id: 'carros',
    nome: 'Consórcio de carros',
    img: '/play-assets/carros.png',
    alt: 'Casal observa um carro em uma concessionária',
  },
  {
    n: '02',
    id: 'pesados',
    nome: 'Consórcio de pesados',
    img: '/play-assets/pesados.png',
    alt: 'Motorista conversa na cabine de um caminhão',
  },
  {
    n: '03',
    id: 'motos',
    nome: 'Consórcio de motos',
    img: '/play-assets/moto.png',
    alt: 'Homem de jaqueta ajusta uma moto em uma garagem',
  },
  {
    n: '04',
    id: 'imoveis',
    nome: 'Consórcio de imóveis',
    img: '/play-assets/imoveis.png',
    alt: 'Pessoas conversam em um apartamento vazio de janelas amplas',
  },
  {
    n: '05',
    id: 'servicos',
    nome: 'Consórcio de serviços',
    img: '/play-assets/servicos.png',
    alt: 'Profissional em ambiente de serviços',
  },
  {
    n: '06',
    id: 'eletro',
    nome: 'Consórcio de eletro',
    img: '/play-assets/eletro.png',
    alt: 'Casal no sofá da sala olhando um tablet',
  },
];

const passos = [
  'Escolha o plano ideal voltado para seu objetivo e com o valor de crédito compatível.',
  'Você passa a integrar um grupo de consórcio e contribui com parcelas mensais.',
  'A cada mês, os participantes devem aguardar serem contemplados por sorteio ou oferta de lance.',
  'Após a contemplação, utilize o crédito para adquirir o bem conforme o segmento contratado.',
];

const vantagens = [
  {
    titulo: 'Sem entrada e juros',
    texto:
      'Comece a poupar e invista no seu objetivo sem pagar juros bancários ou dar entrada no início do plano.',
  },
  {
    titulo: 'Planejamento acessível',
    texto:
      'Parcelas que cabem no bolso e ajudam você a conquistar seus bens com mais tranquilidade.',
  },
  {
    titulo: 'Liberdade de escolha',
    texto:
      'Escolha como e quando usar seu crédito, de acordo com seus objetivos e necessidades nos principais segmentos.',
  },
];

const diferenciais = [
  {
    titulo: 'Consultoria personalizada',
    texto: 'Conte com o apoio de especialistas para escolher o melhor plano e aproveitar as melhores condições.',
  },
  {
    titulo: 'Boas chances de contemplação',
    texto: 'Participe com lances livres, embutidos ou fixos, além dos sorteios mensais pela Loteria Federal.',
  },
  {
    titulo: 'Segurança e transparência',
    texto: 'Clareza em todas as etapas. Sem inconsistências no contrato ou taxas abusivas.',
  },
];

const faq = [
  {
    p: 'Como funciona o consórcio?',
    r: 'O consórcio é uma forma de compra planejada em que um grupo de pessoas contribui mensalmente para formar um fundo comum. Todo mês, um ou mais participantes são contemplados por sorteio ou lance e recebem uma carta de crédito para adquirir o bem desejado, sem juros, apenas com taxa de administração.',
  },
  {
    p: 'O que compõe o valor da minha parcela?',
    r: 'A parcela mensal corresponde à soma dos percentuais referentes ao Fundo Comum, ao Fundo de Reserva, à Taxa de Administração e ao Prêmio de Seguro Prestamista, se contratado.',
  },
  {
    p: 'Consórcio ou financiamento: qual escolher?',
    r: 'O consórcio é ideal para quem quer planejar a compra sem pressa, pois não tem juros, apenas taxa de administração. Já o financiamento libera o bem de imediato, mas inclui juros e pode ter um custo maior ao longo do tempo.',
  },
  {
    p: 'Consórcio vale a pena?',
    r: 'Sim, principalmente para quem deseja planejar a compra sem pagar juros. No Consórcio Nacional MI6, você pode adquirir imóveis, veículos, equipamentos ou eletroeletrônicos com parcelas acessíveis e flexibilidade para ofertar lances e antecipar a contemplação.',
  },
];

// Grupo ativo de motos: parâmetros vêm do espelho da tabela verdade
// (src/dados/grupos.json), que na fase 3 será alimentado pelo Excel do 365.
const grupoMotos = dados.grupos.find((g) => g.segmento === 'motos' && g.status === 'ativo')!;
const brlServidor = (v: number) =>
  'R$ ' + v.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const pct = (v: number) => (v * 100).toLocaleString('pt-BR');
const baseSim = grupoMotos.credito_padrao * (1 + grupoMotos.taxa_administracao + grupoMotos.fundo_reserva);
const simInicial = {
  credito: grupoMotos.credito_padrao.toLocaleString('pt-BR'),
  fc: brlServidor(grupoMotos.credito_padrao / grupoMotos.prazo_restante_meses),
  tx: brlServidor((grupoMotos.credito_padrao * grupoMotos.taxa_administracao) / grupoMotos.prazo_restante_meses),
  fr: brlServidor((grupoMotos.credito_padrao * grupoMotos.fundo_reserva) / grupoMotos.prazo_restante_meses),
  parcela: brlServidor(baseSim / grupoMotos.prazo_restante_meses),
  seguro: brlServidor(baseSim / grupoMotos.prazo_restante_meses + baseSim * grupoMotos.seguro_prestamista_mes),
};

// Marca viva: guias de caligrafia no ângulo do talhe do logo (medido na
// barra vermelha: dx/dy = -0,3345), prolongadas para fora da tela.
const talhe = -0.3345;
const guiaInclinada = (xBase: number) => ({
  x1: xBase + (-1500 - 376) * talhe,
  y1: -1500,
  x2: xBase + (1900 - 376) * talhe,
  y2: 1900,
});
const guiasInclinadas = [60, 250, 640].map(guiaInclinada);
const guiaBarra = guiaInclinada(388);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Conceito A, Dossiê | Play MI6</title>
    <meta name="description" content="Protótipo da FASE 2: inteligência britânica cinematográfica com pulso humano." />
  </head>
  <body>
    <div class="veu" role="dialog" aria-label="Boas-vindas MI6">
      <button type="button" class="veu-pano veu-pano-cliente" data-perfil="cliente">
        <span class="veu-pano-rotulo">Já sou cliente</span>
        <span class="veu-pano-sub">boletos, lances e contemplação</span>
      </button>
      <button type="button" class="veu-pano veu-pano-novo" data-perfil="novo">
        <span class="veu-pano-rotulo">Ainda não sou</span>
        <span class="veu-pano-sub">quero simular meu plano</span>
      </button>
      <div class="veu-centro" aria-hidden="true">
        <span class="veu-linha"></span>
        <div class="veu-miolo">
          <img class="veu-logo" src="/imgs/logo-mi6-branco.png" alt="" width="219" height="47" />
          <p class="veu-pergunta">Como podemos te receber hoje?</p>
        </div>
      </div>
      <button type="button" class="veu-pular" data-perfil="">Entrar sem escolher</button>
    </div>
    <div class="grao" aria-hidden="true"></div>

    <header class="topo">
      <a class="topo-marca" href="/play/conceito-a/">
        <img src="/imgs/logo-mi6.png" alt="MI6 Consórcio Nacional" width="219" height="47" />
      </a>
      <div class="topo-acessos">
        <a class="acesso acesso-cliente" href="https://mi6.evertecinc.com.br/autoatendimento">
          <svg viewBox="0 0 20 20" aria-hidden="true"><circle cx="10" cy="6.6" r="3.1"/><path d="M3.6 17.1c1.2-3 3.5-4.6 6.4-4.6s5.2 1.6 6.4 4.6"/></svg>
          <span>Sou cliente</span>
        </a>
        <a class="topo-cta" href="#contato">Simular</a>
      </div>
    </header>

    <main>
      <section class="hero" id="inicio">
        <svg class="hero-marca" aria-hidden="true" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
          <g class="marca-grupo">
            <line class="guia" x1="-2600" y1="4" x2="3400" y2="4" pathLength="100"></line>
            <line class="guia" x1="-2600" y1="188" x2="3400" y2="188" pathLength="100"></line>
            <line class="guia" x1="-2600" y1="372" x2="3400" y2="372" pathLength="100"></line>
            {
              guiasInclinadas.map((g) => (
                <line class="guia" x1={g.x1} y1={g.y1} x2={g.x2} y2={g.y2} pathLength="100" />
              ))
            }
            <line class="guia guia-rubra" x1={guiaBarra.x1} y1={guiaBarra.y1} x2={guiaBarra.x2} y2={guiaBarra.y2} pathLength="100"></line>
            {marca.letras.map((d) => <path class="traco traco-letras" d={d} pathLength="100" />)}
            {marca.barra.map((d) => <path class="traco traco-barra" d={d} pathLength="100" />)}
          </g>
        </svg>

        <p class="hero-coord" aria-hidden="true">30°02′S 51°13′W · PORTO ALEGRE · BRASIL</p>

        <div class="hero-grade">
          <div class="hero-conteudo">
            <p class="hero-kicker"><span id="scramble">O Melhor Investimento:</span></p>
            <h1 id="titulo">
              <span class="linha">6 caminhos para</span>
              <span class="linha">transformar <em>sonhos</em></span>
              <span class="linha">em conquistas</span>
            </h1>
            <p class="hero-frase" data-intro>Você está perto de realizar o seu projeto de vida</p>
            <div class="hero-acoes" data-intro>
              <a class="cta so-novo" href="#contato">Simule agora</a>
              <a class="cta so-cliente" href="https://mi6.evertecinc.com.br/autoatendimento">Área do Cliente</a>
              <button type="button" class="link-claro sub so-novo" data-folha="funciona">O que é consórcio?</button>
              <button type="button" class="link-claro sub so-cliente" data-folha="contemplacao">Fui contemplado, e agora?</button>
            </div>
            <p class="hero-prova" data-intro>
              <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M10 2.4l6 2.2v4.5c0 4.2-2.6 7-6 8.4-3.4-1.4-6-4.2-6-8.4V4.6z"/><path d="M7.2 10.1l2 2 3.6-3.8"/></svg>
              Administradora autorizada e fiscalizada pelo Banco Central do Brasil
            </p>
          </div>

          <div class="hero-visual">
            <figure class="lente" data-intro>
              <img src="/play-assets/conquista.png" alt="Casal comemora segurando as chaves da casa nova" />
              <span class="lente-anel" aria-hidden="true"></span>
              <span class="lente-anel-dash" aria-hidden="true"></span>
              <span class="lente-tick" aria-hidden="true"></span>
            </figure>
            <aside class="ticket" data-intro aria-label="Plano de motos em destaque">
              <p class="ticket-rotulo">Motos · grupos ativos</p>
              <p class="ticket-valor">Parcelas a partir de <strong>R$ 200,00</strong></p>
              <p class="ticket-dia">menos de R$ 7 por dia</p>
              <a class="sub" href="#contato">Simule agora</a>
            </aside>
          </div>
        </div>

        <p class="hero-scroll" aria-hidden="true">role</p>
      </section>

      <section class="credibilidade" aria-label="Credenciais institucionais">
        <div class="cred-abac">
          <img src="/imgs/abac.svg" alt="ABAC" width="127" height="41" />
          <p>Filiada à ABAC, Associação Brasileira de Administradoras de Consórcios</p>
        </div>
        <span class="cred-divisa" aria-hidden="true"></span>
        <div class="cred-bacen">
          <p class="cred-frase">Autorizada pelo Banco Central do Brasil</p>
          <p class="cred-oficio">Ofício nº 33.288/2024</p>
        </div>
      </section>

      <div class="marquee" aria-hidden="true">
        <div class="marquee-faixa">
          <span>Lei nº 11.795/2008 · SAC 0800 000 5228 · Ouvidoria 0800 000 5267 · Atendimento em todo o Brasil · </span><span>Lei nº 11.795/2008 · SAC 0800 000 5228 · Ouvidoria 0800 000 5267 · Atendimento em todo o Brasil · </span>
        </div>
      </div>

      <section class="galeria" id="solucoes">
        <div class="galeria-pin">
          <header class="galeria-cabeca">
            <p class="indice">SEIS CAMINHOS</p>
            <h2>O consórcio ideal para você</h2>
            <p class="galeria-apoio">
              Trabalhamos com soluções em seis segmentos do mercado, com planos
              flexíveis, atendimento consultivo e foco total em custo-benefício.
              Quem registra interesse entra no início do grupo.
            </p>
          </header>
          <div class="galeria-track">
            {
              segmentos.map((s) => (
                <article class="painel">
                  <div class="painel-foto">
                    <img src={s.img} alt={s.alt} loading="lazy" />
                  </div>
                  <p class="painel-num" aria-hidden="true">{s.n}</p>
                  <h3>{s.nome}</h3>
                  <a class="sub" href="#contato" data-segmento={s.id}>Simule agora</a>
                </article>
              ))
            }
          </div>
          <p class="galeria-dica" aria-hidden="true">passe o cursor para ver em cores</p>
        </div>
      </section>

      <section class="contato" id="contato">
        <svg class="contato-geo" aria-hidden="true" viewBox="0 0 1440 600" preserveAspectRatio="xMidYMid slice">
          <g class="geo-fim-claras" stroke="rgba(255,255,255,0.14)" stroke-width="1">
            <line x1="0" y1="0" x2="1440" y2="600"></line>
            <line x1="1440" y1="0" x2="0" y2="600"></line>
          </g>
          <g class="geo-fim-navy" stroke="rgba(1,33,105,0.28)" stroke-width="1">
            <line x1="80" y1="0" x2="1520" y2="600"></line>
            <line x1="1360" y1="0" x2="-80" y2="600"></line>
          </g>
        </svg>
        <div class="sim-grade">
          <div class="sim-texto">
            <h2 data-reveal>Simule o consórcio <em>ideal</em> para você</h2>
            <p data-reveal>
              Escolha o segmento, ajuste o crédito e veja a conta inteira,
              parcela por parcela, sem letra miúda. Um consultor confirma as
              condições com você.
            </p>
            <ul class="contato-garantias" data-reveal>
              <li>Sem compromisso</li>
              <li>Menos de 2 minutos</li>
              <li>Resposta de gente</li>
            </ul>
            <div class="contato-acoes" data-reveal>
              <a class="cta cta-inverso" href="https://wa.me/5511981406486">Prefiro o WhatsApp</a>
              <span class="contato-alt">ou SAC 0800 000 5228</span>
            </div>
            <p class="contato-nota" data-reveal>
              [ o envio abre o Microsoft Forms incorporado, já preenchido com
              segmento e valores da simulação ]
            </p>
          </div>

          <form
            class="sim-card"
            data-reveal
            aria-label="Simulador de parcela"
            data-prazo={grupoMotos.prazo_restante_meses}
            data-txadm={grupoMotos.taxa_administracao}
            data-fres={grupoMotos.fundo_reserva}
            data-seguro={grupoMotos.seguro_prestamista_mes}
            data-credito-padrao={grupoMotos.credito_padrao}
            data-grupo={grupoMotos.grupo}
            data-dia={grupoMotos.dia_assembleia}
          >
            <p class="sim-passo">01 · O que você quer conquistar?</p>
            <div class="chips" id="sim-chips">
              {
                segmentos.map((s) => (
                  <button type="button" data-segmento={s.id} aria-pressed={s.id === 'motos' ? 'true' : 'false'}>
                    {s.nome.replace('Consórcio de ', '')}
                  </button>
                ))
              }
            </div>

            <div class="sim-vivo" id="sim-vivo">
              <p class="sim-passo">02 · Qual crédito você precisa?</p>
              <p class="sim-credito">
                <span class="sim-moeda">R$</span><output id="sim-valor" for="sim-credito">{simInicial.credito}</output>
              </p>
              <input
                type="range"
                id="sim-credito"
                min={grupoMotos.credito_min}
                max={grupoMotos.credito_max}
                step={grupoMotos.passo_credito}
                value={grupoMotos.credito_padrao}
                aria-label="Valor de crédito desejado"
              />
              <div class="sim-extremos" aria-hidden="true">
                <span>R$ {grupoMotos.credito_min.toLocaleString('pt-BR')}</span>
                <span>R$ {grupoMotos.credito_max.toLocaleString('pt-BR')}</span>
              </div>
              <dl class="sim-conta">
                <div><dt>Fundo comum</dt><dd id="sim-fc">{simInicial.fc}</dd></div>
                <div><dt>Taxa de administração · {pct(grupoMotos.taxa_administracao)}%</dt><dd id="sim-tx">{simInicial.tx}</dd></div>
                <div><dt>Fundo de reserva · {pct(grupoMotos.fundo_reserva)}%</dt><dd id="sim-fr">{simInicial.fr}</dd></div>
                <div class="sim-parcela"><dt>Parcela em {grupoMotos.prazo_restante_meses} meses</dt><dd id="sim-parcela">{simInicial.parcela}</dd></div>
                <div><dt>Com seguro prestamista · {pct(grupoMotos.seguro_prestamista_mes)}%</dt><dd id="sim-seguro">{simInicial.seguro}</dd></div>
              </dl>
              <p class="sim-assembleia">Grupo {grupoMotos.grupo} · assembleias todo dia {grupoMotos.dia_assembleia}</p>
              <button type="button" class="cta sim-cta" id="sim-enviar">Quero esta proposta</button>
              <button type="button" class="sim-cta-sec" id="sim-dossie">
                <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M10 3v9.5"/><path d="m6.6 9.4 3.4 3.4 3.4-3.4"/><path d="M4 16.6h12"/></svg>
                Baixar o dossiê do meu plano
              </button>
              <p class="sim-nota">
                Simulação do plano de motos em vigor. Valores aproximados, sem
                valor contratual; a proposta final vem do consultor.
              </p>
            </div>

            <div class="sim-aguarde" id="sim-aguarde" hidden>
              <p class="sim-aguarde-titulo">Grupos de <strong id="sim-seg-nome">carros</strong> em formação.</p>
              <p>
                Deixe seu contato e receba as condições de abertura em primeira
                mão, com posição no início do grupo.
              </p>
              <button type="button" class="cta sim-cta" id="sim-avisar">Quero ser avisado da abertura</button>
            </div>
          </form>
        </div>
      </section>
    </main>

    <footer class="rodape">
      <div class="rodape-topo">
        <img src="/imgs/logo-mi6-branco.png" alt="MI6 Consórcio Nacional" width="219" height="47" />
        <p class="rodape-frase">O melhor investimento, 6 soluções para tirar seu sonho do papel.</p>
      </div>
      <div class="rodape-colunas">
        <nav aria-label="Institucional">
          <h3>Institucional</h3>
          <button type="button" class="sub" data-folha="funciona">Como funciona</button>
          <button type="button" class="sub" data-folha="contemplacao">Contemplação</button>
          <button type="button" class="sub" data-folha="duvidas">Perguntas frequentes</button>
          <a class="sub" href="#">Política de privacidade</a>
          <button type="button" class="sub" data-trocar-perfil>Trocar perfil de navegação</button>
        </nav>
        <nav aria-label="Consórcios">
          <h3>Consórcios</h3>
          <a class="sub" href="#solucoes">Carros</a>
          <a class="sub" href="#solucoes">Motos</a>
          <a class="sub" href="#solucoes">Pesados</a>
          <a class="sub" href="#solucoes">Imóveis</a>
          <a class="sub" href="#solucoes">Serviços</a>
          <a class="sub" href="#solucoes">Eletro</a>
        </nav>
        <div>
          <h3>Atendimento</h3>
          <p>SAC 0800 000 5228</p>
          <p>Ouvidoria 0800 000 5267</p>
          <p>WhatsApp (11) 98140-6486</p>
          <p>contato@mi6consorcio.com.br</p>
        </div>
        <div>
          <h3>Acesso</h3>
          <a class="sub" href="https://mi6.evertecinc.com.br/autoatendimento">Área do cliente</a>
          <a class="sub" href="https://mi6.evertecinc.com.br/newcon.web/frmCorCCCnsLogin.aspx?applicationKey=3M9zL0+WaLYAeBQwijSQEkhjyy42CGuQj8DXZNFUeAoW7bdn/JfcNmUNbNUgQJqaufUv7kqAamOQCRrx6B2F7w==">Canal do parceiro</a>
          <a class="sub" href="https://www.instagram.com/mi6.consorcio/">Instagram</a>
          <a class="sub" href="https://www.facebook.com/61584214719614/">Facebook</a>
        </div>
      </div>
      <p class="rodape-legal">
        © Todos os direitos reservados. Administradora de consórcios autorizada
        e fiscalizada pelo Banco Central do Brasil, Ofício nº 33.288/2024,
        Lei nº 11.795/2008. Filiada à ABAC.
      </p>
    </footer>

    <nav class="dock" aria-label="Menu flutuante">
      <button type="button" data-folha="funciona">
        <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M10 4.2c-1.6-1.1-3.6-1.4-6-1V15c2.4-.4 4.4-.1 6 1 1.6-1.1 3.6-1.4 6-1V3.2c-2.4-.4-4.4-.1-6 1z"/><path d="M10 4.2V16"/></svg>
        <span>Consórcio</span>
      </button>
      <button type="button" data-folha="contemplacao">
