    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import { SplitText } from 'gsap/SplitText';
      import { ScrambleTextPlugin } from 'gsap/ScrambleTextPlugin';
      import Lenis from 'lenis';

      gsap.registerPlugin(ScrollTrigger, SplitText, ScrambleTextPlugin);

      const motionOk = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;
      if (!motionOk) document.querySelector('.veu')?.remove();

      // Perfil guardado de visitas anteriores reordena os destaques.
      const perfilSalvo = localStorage.getItem('mi6-perfil');
      if (perfilSalvo === 'cliente' || perfilSalvo === 'novo') {
        document.body.dataset.perfil = perfilSalvo;
      }
      document.querySelectorAll('[data-trocar-perfil]').forEach((b) => {
        b.addEventListener('click', () => {
          localStorage.removeItem('mi6-perfil');
          sessionStorage.removeItem('mi6-veu');
          location.reload();
        });
      });

      let lenis: Lenis | null = null;
      if (motionOk) {
        lenis = new Lenis({ autoRaf: true, lerp: 0.12 });
        lenis.on('scroll', ScrollTrigger.update);
        document.querySelectorAll('a[href^="#"]').forEach((a) => {
          a.addEventListener('click', (e) => {
            const alvo = a.getAttribute('href');
            if (alvo && alvo.length > 1) {
              e.preventDefault();
              lenis?.scrollTo(alvo, { offset: -72 });
            }
          });
        });
      }

      // Topo ganha fundo sólido depois da primeira rolagem.
      ScrollTrigger.create({
        start: 60,
        end: 'max',
        toggleClass: { className: 'rolou', targets: '.topo' },
      });

      // Folhas: o conteúdo de apoio sobe em lâminas a partir do dock.
      const fundo = document.getElementById('folha-fundo');
      let folhaAberta: HTMLElement | null = null;
      function abrirFolha(id: string) {
        const folha = document.getElementById(`folha-${id}`);
        if (!folha) return;
        if (folhaAberta === folha) return;
        if (folhaAberta) {
          // Troca direta de lâmina: a aberta sai na hora, a nova entra animada.
          folhaAberta.setAttribute('hidden', '');
          folhaAberta = null;
        }
        folhaAberta = folha;
        fundo?.removeAttribute('hidden');
        folha.removeAttribute('hidden');
        document.documentElement.style.overflow = 'hidden';
        lenis?.stop();
        if (motionOk) {
          gsap.fromTo(fundo, { autoAlpha: 0 }, { autoAlpha: 1, duration: 0.35, ease: 'power2.out' });
          gsap.fromTo(folha, { yPercent: 100 }, { yPercent: 0, duration: 0.55, ease: 'power3.out' });
        }
        folha.querySelector<HTMLButtonElement>('.folha-fechar')?.focus();
      }
      function fecharFolha() {
        const folha = folhaAberta;
        if (!folha) return;
        folhaAberta = null;
        const encerrar = () => {
          folha.setAttribute('hidden', '');
          fundo?.setAttribute('hidden', '');
          document.documentElement.style.overflow = '';
          lenis?.start();
        };
        if (motionOk) {
          gsap.to(fundo, { autoAlpha: 0, duration: 0.3, ease: 'power2.in' });
          gsap.to(folha, { yPercent: 100, duration: 0.4, ease: 'power3.in', onComplete: encerrar });
        } else {
          encerrar();
        }
      }
      document.querySelectorAll<HTMLElement>('[data-folha]').forEach((el) => {
        el.addEventListener('click', () => abrirFolha(el.dataset.folha ?? ''));
      });
      document.querySelectorAll('[data-fechar]').forEach((el) => {
        el.addEventListener('click', fecharFolha);
      });
      fundo?.addEventListener('click', fecharFolha);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') fecharFolha();
      });
      // Link interno dentro de uma folha fecha a lâmina antes de rolar.
      document.querySelectorAll('.folha a[href^="#"]').forEach((a) => {
        a.addEventListener('click', () => fecharFolha());
      });

      // Simulador: a conta inteira do grupo ativo, ao vivo. Os parâmetros
      // chegam pelo HTML, vindos do espelho da tabela verdade (grupos.json).
      const simCard = document.querySelector<HTMLElement>('.sim-card');
      const PRAZO = parseInt(simCard?.dataset.prazo ?? '98', 10);
      const TX_ADM = parseFloat(simCard?.dataset.txadm ?? '0.2');
      const F_RES = parseFloat(simCard?.dataset.fres ?? '0.04');
      const SEGURO = parseFloat(simCard?.dataset.seguro ?? '0.0008');
      const brl = (v: number) =>
        'R$ ' + v.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      const exib = { c: parseInt(simCard?.dataset.creditoPadrao ?? '15000', 10) };
      function pintarSim() {
        const c = exib.c;
        const base = c * (1 + TX_ADM + F_RES);
        const por = (id: string, v: string) => {
          const el = document.getElementById(id);
          if (el) el.textContent = v;
        };
        por('sim-valor', Math.round(c).toLocaleString('pt-BR'));
        por('sim-fc', brl(c / PRAZO));
        por('sim-tx', brl((c * TX_ADM) / PRAZO));
        por('sim-fr', brl((c * F_RES) / PRAZO));
        por('sim-parcela', brl(base / PRAZO));
        por('sim-seguro', brl(base / PRAZO + base * SEGURO));
      }
      const credito = document.getElementById('sim-credito') as HTMLInputElement | null;
      credito?.addEventListener('input', () => {
        const alvo = parseInt(credito.value, 10);
        if (motionOk) {
          gsap.to(exib, { c: alvo, duration: 0.3, ease: 'power2.out', overwrite: true, onUpdate: pintarSim });
        } else {
          exib.c = alvo;
          pintarSim();
        }
      });

      const nomesSeg: Record<string, string> = {
        carros: 'carros',
        pesados: 'pesados',
        motos: 'motos',
        imoveis: 'imóveis',
        servicos: 'serviços',
        eletro: 'eletro',
      };
      function escolherSegmento(id: string) {
        document.querySelectorAll('#sim-chips button').forEach((b) => {
          b.setAttribute('aria-pressed', (b as HTMLElement).dataset.segmento === id ? 'true' : 'false');
        });
        const vivo = document.getElementById('sim-vivo');
        const aguarde = document.getElementById('sim-aguarde');
        const nome = document.getElementById('sim-seg-nome');
        if (id === 'motos') {
          vivo?.removeAttribute('hidden');
          aguarde?.setAttribute('hidden', '');
        } else {
          vivo?.setAttribute('hidden', '');
          aguarde?.removeAttribute('hidden');
          if (nome) nome.textContent = nomesSeg[id] ?? id;
        }
      }
      document.getElementById('sim-chips')?.addEventListener('click', (e) => {
        const b = (e.target as HTMLElement).closest('button');
        if (b?.dataset.segmento) escolherSegmento(b.dataset.segmento);
      });
      document.querySelectorAll<HTMLAnchorElement>('a[data-segmento]').forEach((a) => {
        a.addEventListener('click', () => escolherSegmento(a.dataset.segmento ?? 'motos'));
      });
      ['sim-enviar', 'sim-avisar'].forEach((id) => {
        const b = document.getElementById(id);
        b?.addEventListener('click', () => {
          const original = b.textContent;
          b.textContent = 'Aqui abre o Microsoft Forms preenchido';
          b.setAttribute('disabled', '');
          setTimeout(() => {
            b.textContent = original;
            b.removeAttribute('disabled');
          }, 1800);
        });
      });

      // Dossiê do Plano: o artefato que o lead leva. Desenhado em canvas com
      // a identidade do site e os números da simulação atual; no celular vai
      // direto para a folha de compartilhamento (WhatsApp), no desktop baixa.
      const pctTexto = (v: number) => (v * 100).toLocaleString('pt-BR') + '%';
      async function gerarDossie(): Promise<Blob | null> {
        await Promise.all([
          document.fonts.load('400 130px "Instrument Serif"'),
          document.fonts.load('500 26px "IBM Plex Mono"'),
          document.fonts.load('600 30px "Public Sans Variable"'),
        ]).catch(() => {});
        const W = 1080;
        const H = 1350;
        const cv = document.createElement('canvas');
        cv.width = W;
        cv.height = H;
        const cx2 = cv.getContext('2d');
        if (!cx2) return null;

        const grad = cx2.createRadialGradient(W / 2, 0, 120, W / 2, 0, H * 1.1);
        grad.addColorStop(0, '#022169');
        grad.addColorStop(0.7, '#021a4f');
        grad.addColorStop(1, '#01133a');
        cx2.fillStyle = grad;
        cx2.fillRect(0, 0, W, H);
        cx2.lineWidth = 1;
        cx2.strokeStyle = 'rgba(255,255,255,0.10)';
        cx2.beginPath(); cx2.moveTo(0, 0); cx2.lineTo(W, H); cx2.stroke();
        cx2.beginPath(); cx2.moveTo(W, 0); cx2.lineTo(0, H); cx2.stroke();
        cx2.strokeStyle = 'rgba(200,16,46,0.35)';
        cx2.beginPath(); cx2.moveTo(90, 0); cx2.lineTo(W + 90, H); cx2.stroke();
        cx2.beginPath(); cx2.moveTo(W - 90, 0); cx2.lineTo(-90, H); cx2.stroke();

        const logo = new Image();
        logo.src = '/imgs/logo-mi6-branco.png';
        await new Promise((res) => {
          logo.onload = res;
          logo.onerror = res;
        });
        if (logo.naturalWidth) cx2.drawImage(logo, 84, 78, 233, 50);

        const mono = (px: number) => `500 ${px}px "IBM Plex Mono", monospace`;
        const serif = (px: number) => `400 ${px}px "Instrument Serif", Georgia, serif`;
        const sans = (px: number, w = 600) => `${w} ${px}px "Public Sans Variable", Arial, sans-serif`;

        cx2.fillStyle = 'rgba(255,255,255,0.65)';
        cx2.font = mono(24);
        cx2.textAlign = 'right';
        cx2.fillText('DOSSIÊ DO PLANO', W - 84, 104);
        cx2.fillText(new Date().toLocaleDateString('pt-BR'), W - 84, 138);

        cx2.textAlign = 'left';
        cx2.fillStyle = 'rgba(255,255,255,0.6)';
        cx2.font = mono(26);
        cx2.fillText('CRÉDITO SIMULADO · MOTOS', 84, 318);
        cx2.fillStyle = '#ffffff';
        cx2.font = serif(130);
        cx2.fillText('R$ ' + Math.round(exib.c).toLocaleString('pt-BR'), 78, 442);

        cx2.fillStyle = 'rgba(255,255,255,0.5)';
        cx2.fillRect(84, 502, W - 168, 2);
        cx2.fillStyle = '#c8102e';
        cx2.fillRect(84, 502, 96, 2);

        const base = exib.c * (1 + TX_ADM + F_RES);
        const linhas: Array<[string, string, boolean]> = [
          ['Fundo comum', brl(exib.c / PRAZO), false],
          ['Taxa de administração · ' + pctTexto(TX_ADM), brl((exib.c * TX_ADM) / PRAZO), false],
          ['Fundo de reserva · ' + pctTexto(F_RES), brl((exib.c * F_RES) / PRAZO), false],
          ['Parcela em ' + PRAZO + ' meses', brl(base / PRAZO), true],
          ['Com seguro prestamista · ' + pctTexto(SEGURO), brl(base / PRAZO + base * SEGURO), false],
        ];
        let y = 596;
        for (const [rotulo, valor, destaque] of linhas) {
          cx2.textAlign = 'left';
          cx2.fillStyle = destaque ? '#ffffff' : 'rgba(255,255,255,0.7)';
          cx2.font = destaque ? sans(33, 700) : sans(29, 500);
          cx2.fillText(rotulo, 84, y);
          cx2.textAlign = 'right';
          cx2.fillStyle = '#ffffff';
          cx2.font = destaque ? serif(62) : sans(33, 600);
          cx2.fillText(valor, W - 84, destaque ? y + 6 : y);
          if (destaque) {
            cx2.fillStyle = '#c8102e';
            cx2.fillRect(W - 84 - 300, y + 28, 300, 3);
          } else {
            cx2.fillStyle = 'rgba(255,255,255,0.14)';
            cx2.fillRect(84, y + 26, W - 168, 1);
          }
          y += destaque ? 112 : 84;
        }

        const grupoId = simCard?.dataset.grupo ?? 'M-01';
        const diaAss = simCard?.dataset.dia ?? '20';
        cx2.textAlign = 'left';
        cx2.fillStyle = 'rgba(255,255,255,0.6)';
        cx2.font = mono(24);
        cx2.fillText('GRUPO ' + grupoId + ' · ' + PRAZO + ' MESES · ASSEMBLEIAS DIA ' + diaAss, 84, 1126);
        cx2.fillStyle = 'rgba(255,255,255,0.45)';
        cx2.font = sans(22, 500);
        cx2.fillText('Valores aproximados, sem valor contratual. A proposta final vem do consultor.', 84, 1168);
        cx2.fillStyle = '#c8102e';
        cx2.fillRect(84, 1214, W - 168, 3);
        cx2.fillStyle = 'rgba(255,255,255,0.82)';
        cx2.font = sans(24, 600);
        cx2.fillText('Autorizada pelo Banco Central do Brasil · Ofício nº 33.288/2024', 84, 1262);
        cx2.textAlign = 'right';
        cx2.fillText('mi6consorcio.com.br', W - 84, 1300);
        return await new Promise((res) => cv.toBlob(res, 'image/png'));
      }

      const botaoDossie = document.getElementById('sim-dossie');
      botaoDossie?.addEventListener('click', async () => {
        if (botaoDossie.hasAttribute('disabled')) return;
        const original = botaoDossie.innerHTML;
        botaoDossie.setAttribute('disabled', '');
        botaoDossie.textContent = 'Preparando seu dossiê...';
        try {
          const blob = await gerarDossie();
          if (blob) {
            const arquivo = new File([blob], 'dossie-mi6-motos.png', { type: 'image/png' });
            const podeCompartilhar =
              typeof navigator.canShare === 'function' && navigator.canShare({ files: [arquivo] });
            if (podeCompartilhar) {
              await navigator.share({ files: [arquivo], title: 'Meu plano MI6' }).catch(() => {});
            } else {
              const url = URL.createObjectURL(blob);
              const a = document.createElement('a');
              a.href = url;
              a.download = 'dossie-mi6-motos.png';
              a.click();
              setTimeout(() => URL.revokeObjectURL(url), 4000);
            }
            botaoDossie.textContent = 'Dossiê gerado!';
          }
        } finally {
          setTimeout(() => {
            botaoDossie.innerHTML = original;
            botaoDossie.removeAttribute('disabled');
          }, 1800);
        }
      });

      const mm = gsap.matchMedia();

      mm.add('(prefers-reduced-motion: no-preference)', () => {
        const split = new SplitText('#titulo .linha', { type: 'lines', mask: 'lines' });
        const tl = gsap.timeline({ paused: true, defaults: { ease: 'power4.out' } });
        tl.from('.topo', { yPercent: -100, duration: 0.8, ease: 'power2.out' })
          .to('#scramble', {
            duration: 1.4,
            scrambleText: { text: 'O Melhor Investimento:', chars: 'MI6·01/', speed: 0.4 },
          }, 0.15)
          .from(split.lines, { yPercent: 115, duration: 1.1, stagger: 0.14 }, 0.4)
          .from('[data-intro]', { y: 28, autoAlpha: 0, duration: 0.9, stagger: 0.14 }, '-=0.55')
          .from('.hero-marca', { autoAlpha: 0, duration: 1.4, ease: 'power2.out' }, 0.2)
          .from('.hero-coord, .hero-scroll', { autoAlpha: 0, duration: 0.8 }, '-=0.8')
          .from('.dock', { y: 90, autoAlpha: 0, duration: 0.8, ease: 'power3.out' }, '-=0.9');

        // Cortina-pergunta: a linha desenha, o logo é revelado, os dois
        // panos perguntam o perfil e a cortina abre para os lados.
        // Pergunta uma vez; a escolha fica guardada (trocável no rodapé),
        // é escapável (Esc ou "entrar sem escolher") e a página completa
        // existe por baixo, intacta para buscadores.
        const veu = document.querySelector<HTMLElement>('.veu');
        const abrirCortina = (escolha: string) => {
          if (escolha === 'cliente' || escolha === 'novo') {
            localStorage.setItem('mi6-perfil', escolha);
            document.body.dataset.perfil = escolha;
          }
          gsap.timeline({
            onComplete: () => {
              document.documentElement.style.overflow = '';
              veu?.remove();
            },
          })
            .to('.veu-centro, .veu-pular', { autoAlpha: 0, duration: 0.25 }, 0)
            .to('.veu-pano-cliente', { xPercent: -101, duration: 0.85, ease: 'power3.inOut' }, 0.05)
            .to('.veu-pano-novo', { xPercent: 101, duration: 0.85, ease: 'power3.inOut' }, 0.05)
            .add(() => tl.play(), '-=0.5');
        };
        if (veu && !sessionStorage.getItem('mi6-veu') && !perfilSalvo) {
          sessionStorage.setItem('mi6-veu', '1');
          veu.style.visibility = 'visible';
          document.documentElement.style.overflow = 'hidden';
          gsap.timeline()
            .to('.veu-linha', { scaleX: 1, duration: 0.55, ease: 'power2.inOut' })
            .to('.veu-logo', { clipPath: 'inset(0 0% 0 0)', duration: 0.85, ease: 'power3.inOut' }, '-=0.15')
            .to('.veu-pano-rotulo, .veu-pano-sub', { autoAlpha: 1, duration: 0.6, stagger: 0.08 }, '-=0.2')
            .to('.veu-pergunta, .veu-pular', { autoAlpha: 1, duration: 0.5 }, '-=0.35');
          veu.querySelectorAll<HTMLElement>('[data-perfil]').forEach((b) => {
            b.addEventListener('click', () => abrirCortina(b.dataset.perfil ?? ''));
          });
          document.addEventListener('keydown', function escCortina(e) {
            if (e.key === 'Escape' && veu && document.body.contains(veu)) {
              abrirCortina('');
              document.removeEventListener('keydown', escCortina);
            }
          });
        } else {
          veu?.remove();
          tl.play();
        }

        // A lente gira devagar e respira com o scroll.
        gsap.to('.lente-anel-dash', { rotation: 360, duration: 110, repeat: -1, ease: 'none' });
        gsap.to('.lente', {
          y: -34,
          ease: 'none',
          scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: true },
        });
        gsap.to('.hero-marca', {
          yPercent: -6,
          ease: 'none',
          scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: true },
        });

        // A caneta percorre o caderno: primeiro o contorno das letras, depois
        // a barra, e então escapa pelas guias até fora da tela; segura e
        // recolhe (yoyo), repetindo a dança.
        const caneta = [
          ...gsap.utils.toArray<SVGPathElement>('.traco-letras'),
          ...gsap.utils.toArray<SVGPathElement>('.traco-barra'),
          ...gsap.utils.toArray<SVGLineElement>('.guia'),
        ];
        gsap.set(caneta, { strokeDashoffset: 100 });
        gsap.to(caneta, {
          strokeDashoffset: 0,
          duration: 2.6,
          ease: 'sine.inOut',
          stagger: 0.3,
          repeat: -1,
          yoyo: true,
          repeatDelay: 1.1,
        });

        gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach((el) => {
          gsap.from(el, {
            y: 36,
            autoAlpha: 0,
            duration: 0.9,
            ease: 'power3.out',
            scrollTrigger: { trigger: el, start: 'top 86%' },
          });
        });

        return () => split.revert();
      });

      mm.add('(min-width: 960px) and (prefers-reduced-motion: no-preference)', () => {
        // A foto da lente deriva alguns pixels seguindo o cursor.
        const heroEl = document.querySelector<HTMLElement>('.hero');
        const lenteImg = document.querySelector('.lente img');
        if (heroEl && lenteImg) {
          const lx = gsap.quickTo(lenteImg, 'x', { duration: 0.9, ease: 'power3' });
          const ly = gsap.quickTo(lenteImg, 'y', { duration: 0.9, ease: 'power3' });
          heroEl.addEventListener('mousemove', (e) => {
            const r = heroEl.getBoundingClientRect();
            lx(((e.clientX - r.left) / r.width - 0.5) * 16);
            ly(((e.clientY - r.top) / r.height - 0.5) * 12);
          });
        }

        const track = document.querySelector<HTMLElement>('.galeria-track');
        if (!track) return;
        const distancia = () => track.scrollWidth - window.innerWidth + 96;
        const anim = gsap.to(track, {
          x: () => -distancia(),
          ease: 'none',
          scrollTrigger: {
            trigger: '.galeria',
            start: 'top top',
            end: () => '+=' + distancia(),
            scrub: 1,
            pin: true,
            anticipatePin: 1,
            invalidateOnRefresh: true,
          },
        });
        return () => anim.scrollTrigger?.kill();
      });
    </script>
