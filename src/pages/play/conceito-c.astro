---
import '@fontsource-variable/source-serif-4';
import '@fontsource-variable/archivo';

// CONCEITO C, PAINEL (v2)
// Tese: conversão como produto. Grade suíça em branco, números em Archivo,
// títulos em Source Serif, vermelho reservado ao CTA. A primeira dobra já é
// o início da proposta (segmento + parcela), e cada seção devolve ao mesmo
// destino. Texto: o do site atual, com ajuste fino.

const segmentos = [
  { id: 'carros', nome: 'Consórcio de carros', img: '/play-assets/carros.png', status: 'Em breve' },
  { id: 'pesados', nome: 'Consórcio de pesados', img: '/play-assets/pesados.png', status: 'Em breve' },
  { id: 'motos', nome: 'Consórcio de motos', img: '/play-assets/moto.png', status: 'Grupos ativos', ativo: true },
  { id: 'imoveis', nome: 'Consórcio de imóveis', img: '/play-assets/imoveis.png', status: 'Em breve' },
  { id: 'servicos', nome: 'Consórcio de serviços', img: '/play-assets/servicos.png', status: 'Em breve' },
  { id: 'eletro', nome: 'Consórcio de eletro', img: '/play-assets/eletro.png', status: 'Em breve' },
];

const passos = [
  'Escolha o plano ideal voltado para seu objetivo e com o valor de crédito compatível.',
  'Você passa a integrar um grupo de consórcio e contribui com parcelas mensais.',
  'A cada mês, os participantes devem aguardar serem contemplados por sorteio ou oferta de lance.',
  'Após a contemplação, utilize o crédito para adquirir o bem conforme o segmento contratado.',
];

const comparativo = {
  financiamento: ['Entrada obrigatória', 'Juros elevados', 'Custo total maior', 'Burocracia no crédito', 'Pressão para comprar'],
  consorcio: ['Sem entrada', 'Sem juros', 'Economia no total', 'Processo transparente', 'Liberdade para comprar'],
};

const faq = [
  {
    p: 'O que compõe o valor da minha parcela?',
    r: 'A parcela mensal corresponde à soma dos percentuais referentes ao Fundo Comum, ao Fundo de Reserva, à Taxa de Administração e ao Prêmio de Seguro Prestamista, se contratado.',
  },
  {
    p: 'A carta contemplada é a mesma que a carta de crédito?',
    r: 'Carta contemplada é o mesmo que cota contemplada, uma cota que já foi contemplada por sorteio ou lance. Já a carta de crédito é o documento que representa o valor disponível para a compra do bem.',
  },
  {
    p: 'Consórcio vale a pena?',
    r: 'Sim, principalmente para quem deseja planejar a compra sem pagar juros. No Consórcio Nacional MI6, você pode adquirir imóveis, veículos, equipamentos ou eletroeletrônicos com parcelas acessíveis e flexibilidade para ofertar lances.',
  },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Conceito C, Painel | Play MI6</title>
    <meta name="description" content="Protótipo da FASE 2: conversão como produto, grade suíça e proposta na primeira dobra." />
  </head>
  <body>
    <header class="topo">
      <a class="topo-marca" href="/play/conceito-c/">
        <img src="/imgs/logo-mi6.png" alt="MI6 Consórcio Nacional" width="219" height="60" />
      </a>
      <nav aria-label="Navegação principal">
        <a href="#segmentos">Consórcio</a>
        <a href="#metodo">Passo a passo</a>
        <a href="#comparar">Comparar</a>
        <a href="#faq">Dúvidas</a>
        <a class="topo-cliente" href="https://mi6.evertecinc.com.br/autoatendimento">Área do cliente</a>
      </nav>
      <a class="cta topo-cta" href="#contato">Simule agora</a>
    </header>

    <main>
      <section class="hero">
        <div class="hero-texto">
          <p class="rotulo" data-intro>Consórcio Nacional MI6</p>
          <h1 data-intro>O consórcio <em>ideal</em> para você</h1>
          <p class="hero-apoio" data-intro>
            Trabalhamos com soluções em seis segmentos do mercado, com planos
            flexíveis, atendimento consultivo e foco total em custo-benefício.
            Orientação personalizada para que cada cliente encontre a melhor
            alternativa e alcance seus objetivos.
          </p>
          <ul class="hero-fatos" data-intro>
            <li>Sem entrada e sem juros</li>
            <li>Autorizada pelo Banco Central</li>
            <li>Lei nº 11.795/2008</li>
          </ul>
        </div>

        <form class="modulo" data-intro aria-label="Comece sua proposta" action="#contato" method="get">
          <p class="modulo-passo">01 · O que você quer conquistar?</p>
          <div class="chips" id="chips-segmento" role="group" aria-label="Segmentos">
            {
              segmentos.map((s, i) => (
                <button type="button" data-segmento={s.id} aria-pressed={s.ativo ? 'true' : 'false'}>
                  {s.nome.replace('Consórcio de ', '')}
                </button>
              ))
            }
          </div>
          <p class="modulo-passo">02 · Qual parcela cabe no seu mês?</p>
          <p class="modulo-valor" aria-live="polite">
            <span class="modulo-moeda">R$</span><output id="valor-parcela" for="parcela">500</output><span class="modulo-mes">/mês</span>
          </p>
          <input type="range" id="parcela" min="200" max="2500" step="50" value="500" aria-label="Valor de parcela mensal" />
          <div class="modulo-extremos" aria-hidden="true"><span>R$ 200</span><span>R$ 2.500</span></div>
          <a class="cta modulo-cta" id="cta-proposta" href="#contato">Simule agora</a>
          <p class="modulo-micro" id="resumo">Motos · parcela em torno de R$ 500 por mês</p>
        </form>
      </section>

      <ul class="medidas" aria-label="Dados de confiança">
        <li data-reveal>
          <p class="medidas-num">6</p>
          <p>segmentos, de motos a imóveis</p>
        </li>
        <li data-reveal>
          <p class="medidas-num">0<span>%</span></p>
          <p>de juros; taxa de administração definida em contrato</p>
        </li>
        <li data-reveal>
          <p class="medidas-num">+<span id="contador" data-alvo="1.27">1,27</span> mi</p>
          <p>contemplados no setor em 2024 (fonte: ABAC)</p>
        </li>
        <li data-reveal>
          <p class="medidas-num">dez<span>/2024</span></p>
          <p>autorização do Banco Central do Brasil</p>
        </li>
      </ul>

      <section class="segmentos" id="segmentos">
        <div class="secao-cabeca">
          <h2 data-reveal>Descubra a solução ideal<br />para sua necessidade</h2>
          <p data-reveal>Passe o cursor para ver cada caminho; clique e comece a proposta com o segmento já selecionado.</p>
        </div>
        <ul class="tabela" id="tabela-segmentos">
          {
            segmentos.map((s, i) => (
              <li>
                <a href="#contato" data-img={s.img} data-segmento={s.id} class={s.ativo ? 'ativo' : ''}>
                  <span class="tabela-num">{String(i + 1).padStart(2, '0')}</span>
                  <span class="tabela-nome">{s.nome}</span>
                  <span class="tabela-status">{s.ativo ? 'Grupos ativos · a partir de R$ 200,00' : s.status}</span>
                  <span class="tabela-seta" aria-hidden="true">&#8594;</span>
                </a>
              </li>
            ))
          }
        </ul>
        <div class="preview" id="preview" aria-hidden="true">
          <img id="preview-img" src="/play-assets/moto.png" alt="" />
        </div>
      </section>

      <section class="metodo" id="metodo">
        <div class="secao-cabeca">
          <h2 data-reveal>Passo a passo do<br />Consórcio Nacional MI6</h2>
          <p data-reveal>Veja como realizar seus objetivos com segurança, liberdade e sem juros.</p>
        </div>
        <ol class="metodo-grade">
          {
            passos.map((p, i) => (
              <li data-reveal>
                <p class="metodo-num">{String(i + 1).padStart(2, '0')}</p>
                <p>{p}</p>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="comparar" id="comparar">
        <div class="secao-cabeca">
          <h2 data-reveal>Consórcio ou financiamento?</h2>
          <p data-reveal>Compare e descubra por que o consórcio é a escolha mais econômica e estratégica para executar seus planos.</p>
        </div>
        <div class="comparar-grade" data-reveal>
          <div class="comparar-col">
            <h3>Financiamento</h3>
            <ul>
              {comparativo.financiamento.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="comparar-col comparar-mi6">
            <h3>Consórcio <span>MI6</span></h3>
            <ul>
              {comparativo.consorcio.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </section>

      <section class="faq" id="faq">
        <div class="secao-cabeca">
          <h2 data-reveal>Perguntas frequentes</h2>
          <p data-reveal>
            Documentos públicos: <a href="/docs/regulamento.pdf">Regulamento</a> e
            <a href="/docs/contrato-adesao.pdf">Contrato de adesão</a>.
          </p>
        </div>
        <div class="faq-lista">
          {
            faq.map((item) => (
              <details data-reveal>
                <summary>{item.p}</summary>
                <p>{item.r}</p>
              </details>
            ))
          }
        </div>
      </section>

      <section class="contato" id="contato">
        <div class="contato-texto">
          <h2 data-reveal>Em breve, simule o consórcio ideal para você</h2>
          <p data-reveal>
            Enquanto isso, peça sua proposta: um consultor responde com as
            condições do segmento escolhido, sem compromisso.
          </p>
          <div class="forms-placeholder" data-reveal>
            <p>[ Microsoft Forms incorporado aqui, com segmento e parcela pré-selecionados ]</p>
          </div>
        </div>
        <aside class="contato-humano" data-reveal>
          <h3>Prefere conversar?</h3>
          <p><a href="https://wa.me/5511981406486">WhatsApp (11) 98140-6486</a></p>
          <p>SAC 0800 000 5228</p>
          <p>Ouvidoria 0800 000 5267</p>
          <p>contato@mi6consorcio.com.br</p>
        </aside>
      </section>
    </main>

    <footer class="rodape">
      <div class="rodape-grade">
        <div>
          <img src="/imgs/logo-mi6.png" alt="MI6 Consórcio Nacional" width="219" height="60" />
          <p class="rodape-frase">O melhor investimento, 6 soluções para tirar seu sonho do papel.</p>
        </div>
        <nav aria-label="Links do rodapé">
          <a href="#segmentos">Consórcios</a>
          <a href="#metodo">Passo a passo</a>
          <a href="https://mi6.evertecinc.com.br/autoatendimento">Área do cliente</a>
          <a href="https://mi6.evertecinc.com.br/newcon.web/frmCorCCCnsLogin.aspx?applicationKey=3M9zL0+WaLYAeBQwijSQEkhjyy42CGuQj8DXZNFUeAoW7bdn/JfcNmUNbNUgQJqaufUv7kqAamOQCRrx6B2F7w==">Canal do parceiro</a>
          <a href="https://www.instagram.com/mi6.consorcio/">Instagram</a>
          <a href="https://www.facebook.com/61584214719614/">Facebook</a>
          <a href="#">Política de privacidade</a>
        </nav>
      </div>
      <p class="rodape-legal">
        © Todos os direitos reservados. Administradora de consórcios autorizada
        e fiscalizada pelo Banco Central do Brasil, Lei nº 11.795/2008.
      </p>
    </footer>

    <nav class="play-nav" aria-label="Navegação entre protótipos">
      <a href="/play/">Play</a>
      <a href="/play/conceito-a/">A</a>
      <a href="/play/conceito-b/">B</a>
      <a href="/play/conceito-c/" aria-current="page">C</a>
    </nav>

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import Lenis from 'lenis';

      gsap.registerPlugin(ScrollTrigger);

      const motionOk = window.matchMedia('(prefers-reduced-motion: no-preference)').matches;

      if (motionOk) {
        const lenis = new Lenis({ autoRaf: true, lerp: 0.13 });
        lenis.on('scroll', ScrollTrigger.update);
        document.querySelectorAll('a[href^="#"]').forEach((a) => {
          a.addEventListener('click', (e) => {
            const alvo = a.getAttribute('href');
            if (alvo && alvo.length > 1) {
              e.preventDefault();
              lenis.scrollTo(alvo, { offset: -70 });
            }
          });
        });
      }

      // Estado da proposta (segmento + parcela), refletido no resumo.
      const nomes: Record<string, string> = {
        carros: 'Carros',
        pesados: 'Pesados',
        motos: 'Motos',
        imoveis: 'Imóveis',
        servicos: 'Serviços',
        eletro: 'Eletro',
      };
      const estado = { segmento: 'motos', parcela: 500 };
      const resumo = document.getElementById('resumo');
      const valor = document.getElementById('valor-parcela');
      const faixa = document.getElementById('parcela') as HTMLInputElement | null;

      function atualizar() {
        if (valor) valor.textContent = estado.parcela.toLocaleString('pt-BR');
        if (resumo) {
          resumo.textContent = `${nomes[estado.segmento]} · parcela em torno de R$ ${estado.parcela.toLocaleString('pt-BR')} por mês`;
        }
      }

      document.getElementById('chips-segmento')?.addEventListener('click', (e) => {
        const botao = (e.target as HTMLElement).closest('button');
        if (!botao) return;
        document
          .querySelectorAll('#chips-segmento button')
          .forEach((b) => b.setAttribute('aria-pressed', 'false'));
        botao.setAttribute('aria-pressed', 'true');
        estado.segmento = botao.dataset.segmento ?? 'motos';
        atualizar();
      });

      let alvoParcela = 500;
      faixa?.addEventListener('input', () => {
        alvoParcela = parseInt(faixa.value, 10);
        if (motionOk) {
          gsap.to(estado, {
            parcela: alvoParcela,
            duration: 0.35,
            ease: 'power2.out',
            snap: { parcela: 50 },
            overwrite: true,
            onUpdate: atualizar,
          });
        } else {
          estado.parcela = alvoParcela;
          atualizar();
        }
      });

      // A linha da tabela escolhe o segmento antes de levar ao formulário.
      document.querySelectorAll<HTMLAnchorElement>('#tabela-segmentos a').forEach((linha) => {
        linha.addEventListener('click', () => {
          const seg = linha.dataset.segmento;
          const chip = document.querySelector<HTMLButtonElement>(`#chips-segmento button[data-segmento="${seg}"]`);
          chip?.click();
        });
      });

      const mm = gsap.matchMedia();

      mm.add('(prefers-reduced-motion: no-preference)', () => {
        gsap.from('[data-intro]', {
          y: 26,
          autoAlpha: 0,
          duration: 0.85,
          stagger: 0.1,
          ease: 'power3.out',
          delay: 0.1,
        });

        gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach((el) => {
          gsap.from(el, {
            y: 30,
            autoAlpha: 0,
            duration: 0.8,
            ease: 'power3.out',
            scrollTrigger: { trigger: el, start: 'top 88%' },
          });
        });

        const contador = document.getElementById('contador');
        if (contador) {
          const alvo = parseFloat(contador.dataset.alvo ?? '0');
          const obj = { v: 0 };
          contador.textContent = '0,00';
          gsap.to(obj, {
            v: alvo,
            duration: 1.8,
            ease: 'power2.out',
            scrollTrigger: { trigger: '.medidas', start: 'top 82%' },
            onUpdate: () => {
              contador.textContent = obj.v.toLocaleString('pt-BR', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2,
              });
            },
          });
        }
      });

      // Preview de foto que segue o cursor na tabela de segmentos.
      mm.add('(min-width: 960px) and (prefers-reduced-motion: no-preference) and (hover: hover)', () => {
        const tabela = document.getElementById('tabela-segmentos');
        const preview = document.getElementById('preview');
        const previewImg = document.getElementById('preview-img') as HTMLImageElement | null;
        if (!tabela || !preview || !previewImg) return;

        const setX = gsap.quickTo(preview, 'x', { duration: 0.4, ease: 'power3' });
        const setY = gsap.quickTo(preview, 'y', { duration: 0.4, ease: 'power3' });

        tabela.addEventListener('mousemove', (e) => {
          setX(e.clientX + 24);
          setY(e.clientY - 110);
        });
        tabela.querySelectorAll('a').forEach((linha) => {
          linha.addEventListener('mouseenter', () => {
            const img = linha.dataset.img;
            if (img) previewImg.src = img;
            gsap.to(preview, { autoAlpha: 1, scale: 1, duration: 0.35, ease: 'power3.out' });
          });
        });
        tabela.addEventListener('mouseleave', () => {
          gsap.to(preview, { autoAlpha: 0, scale: 0.92, duration: 0.3, ease: 'power3.in' });
        });
      });
    </script>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    --navy: #012169;
    --tinta: #0e1320;
    --vermelho: #c8102e;
    --branco: #ffffff;
    --cinza: #5b6270;
    --cinza-claro: #f1f2f5;
    --linha: rgba(14, 19, 32, 0.14);
    background: var(--branco);
    color: var(--tinta);
    font-family: 'Archivo Variable', 'Helvetica Neue', Arial, sans-serif;
    line-height: 1.55;
    overflow-x: hidden;
  }
  ::selection {
    background: var(--navy);
    color: var(--branco);
  }
  h1,
  h2,
  h3 {
    font-family: 'Source Serif 4 Variable', Georgia, serif;
    font-weight: 560;
    color: var(--navy);
    margin: 0;
    letter-spacing: -0.01em;
  }
  h1 em,
  h2 em {
    font-style: italic;
    color: var(--vermelho);
  }
  .rotulo {
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--cinza);
    margin: 0 0 1rem;
  }
  .cta {
    display: inline-block;
    background: var(--vermelho);
    color: var(--branco);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.9rem 1.7rem;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .cta:hover {
    background: #a50d26;
    transform: translateY(-2px);
  }

  /* Topo */
  .topo {
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 0.85rem 2.5rem;
    border-bottom: 1px solid var(--linha);
  }
  .topo-marca img {
    height: 2.15rem;
    width: auto;
    display: block;
  }
  .topo nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    font-size: 0.9rem;
    font-weight: 500;
  }
  .topo nav a {
    color: var(--tinta);
    text-decoration: none;
  }
  .topo nav a:hover {
    color: var(--vermelho);
  }
  .topo-cliente {
    color: var(--navy) !important;
    text-decoration: underline !important;
    text-underline-offset: 3px;
  }
  .topo-cta {
    padding: 0.6rem 1.3rem;
  }

  /* Hero */
  .hero {
    max-width: 78rem;
    margin: 0 auto;
    padding: 5rem 2.5rem 4rem;
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    gap: 4rem;
    align-items: center;
  }
  .hero h1 {
    font-size: clamp(2.6rem, 5.6vw, 4.6rem);
    line-height: 1.04;
    margin-bottom: 1.5rem;
  }
  .hero-apoio {
    color: var(--cinza);
    font-size: 1.05rem;
    max-width: 36rem;
    margin: 0 0 1.75rem;
  }
  .hero-fatos {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 0;
    padding: 0;
  }
  .hero-fatos li {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--navy);
    border: 1px solid var(--linha);
    padding: 0.4rem 0.8rem;
    background: var(--cinza-claro);
  }

  /* Módulo de proposta */
  .modulo {
    border: 1px solid var(--linha);
    border-top: 4px solid var(--vermelho);
    background: var(--branco);
    box-shadow: 0 24px 48px -32px rgba(1, 33, 105, 0.35);
    padding: 1.9rem;
    margin: 0;
  }
  .modulo-passo {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cinza);
    margin: 0 0 0.8rem;
  }
  .modulo-passo + .modulo-passo {
    margin-top: 1.5rem;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .chips button {
    font: inherit;
    font-size: 0.88rem;
    font-weight: 600;
    padding: 0.5rem 0.95rem;
    background: var(--branco);
    border: 1px solid var(--linha);
    color: var(--tinta);
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
  }
  .chips button:hover {
    border-color: var(--navy);
    color: var(--navy);
  }
  .chips button[aria-pressed='true'] {
    background: var(--navy);
    border-color: var(--navy);
    color: var(--branco);
  }
  .modulo-valor {
    margin: 0.5rem 0 0.4rem;
    color: var(--navy);
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }
  .modulo-moeda {
    font-weight: 600;
    color: var(--cinza);
  }
  .modulo-valor output {
    font-family: 'Archivo Variable', sans-serif;
    font-variation-settings: 'wdth' 125;
    font-weight: 800;
    font-size: clamp(2.6rem, 4.5vw, 3.6rem);
    line-height: 1;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
