---
import '@fontsource/instrument-serif';
import '@fontsource/instrument-serif/400-italic.css';
import '@fontsource-variable/public-sans';
import '@fontsource/ibm-plex-mono';
import '@fontsource/ibm-plex-mono/500.css';
import dados from '../../dados/grupos.json';
import marca from '../../dados/mi6-traco.json';

// CONCEITO A, DOSSIÊ (v2.1)
// Refino pós-feedback: mantém a modernidade navy cinematográfica e ganha a
// humanização do conceito B. Foto humana em duotone dentro de uma lente
// circular no hero, ritmo claro/escuro entre seções, fotos que ganham cor
// ao toque. Texto: o do site atual, com ajuste fino.

const segmentos = [
  {
    n: '01',
    id: 'carros',
    nome: 'Consórcio de carros',
    img: '/play-assets/carros.png',
    alt: 'Casal observa um carro em uma concessionária',
  },
  {
    n: '02',
    id: 'pesados',
    nome: 'Consórcio de pesados',
    img: '/play-assets/pesados.png',
    alt: 'Motorista conversa na cabine de um caminhão',
  },
  {
    n: '03',
    id: 'motos',
    nome: 'Consórcio de motos',
    img: '/play-assets/moto.png',
    alt: 'Homem de jaqueta ajusta uma moto em uma garagem',
  },
  {
    n: '04',
    id: 'imoveis',
    nome: 'Consórcio de imóveis',
    img: '/play-assets/imoveis.png',
    alt: 'Pessoas conversam em um apartamento vazio de janelas amplas',
  },
  {
    n: '05',
    id: 'servicos',
    nome: 'Consórcio de serviços',
    img: '/play-assets/servicos.png',
    alt: 'Profissional em ambiente de serviços',
  },
  {
    n: '06',
    id: 'eletro',
    nome: 'Consórcio de eletro',
    img: '/play-assets/eletro.png',
    alt: 'Casal no sofá da sala olhando um tablet',
  },
];

const passos = [
  'Escolha o plano ideal voltado para seu objetivo e com o valor de crédito compatível.',
  'Você passa a integrar um grupo de consórcio e contribui com parcelas mensais.',
  'A cada mês, os participantes devem aguardar serem contemplados por sorteio ou oferta de lance.',
  'Após a contemplação, utilize o crédito para adquirir o bem conforme o segmento contratado.',
];

const vantagens = [
  {
    titulo: 'Sem entrada e juros',
    texto:
      'Comece a poupar e invista no seu objetivo sem pagar juros bancários ou dar entrada no início do plano.',
  },
  {
    titulo: 'Planejamento acessível',
    texto:
      'Parcelas que cabem no bolso e ajudam você a conquistar seus bens com mais tranquilidade.',
  },
  {
    titulo: 'Liberdade de escolha',
    texto:
      'Escolha como e quando usar seu crédito, de acordo com seus objetivos e necessidades nos principais segmentos.',
  },
];

const diferenciais = [
  {
    titulo: 'Consultoria personalizada',
    texto: 'Conte com o apoio de especialistas para escolher o melhor plano e aproveitar as melhores condições.',
  },
  {
    titulo: 'Boas chances de contemplação',
    texto: 'Participe com lances livres, embutidos ou fixos, além dos sorteios mensais pela Loteria Federal.',
  },
  {
    titulo: 'Segurança e transparência',
    texto: 'Clareza em todas as etapas. Sem inconsistências no contrato ou taxas abusivas.',
  },
];

const faq = [
  {
    p: 'Como funciona o consórcio?',
    r: 'O consórcio é uma forma de compra planejada em que um grupo de pessoas contribui mensalmente para formar um fundo comum. Todo mês, um ou mais participantes são contemplados por sorteio ou lance e recebem uma carta de crédito para adquirir o bem desejado, sem juros, apenas com taxa de administração.',
  },
  {
    p: 'O que compõe o valor da minha parcela?',
    r: 'A parcela mensal corresponde à soma dos percentuais referentes ao Fundo Comum, ao Fundo de Reserva, à Taxa de Administração e ao Prêmio de Seguro Prestamista, se contratado.',
  },
  {
    p: 'Consórcio ou financiamento: qual escolher?',
    r: 'O consórcio é ideal para quem quer planejar a compra sem pressa, pois não tem juros, apenas taxa de administração. Já o financiamento libera o bem de imediato, mas inclui juros e pode ter um custo maior ao longo do tempo.',
  },
  {
    p: 'Consórcio vale a pena?',
    r: 'Sim, principalmente para quem deseja planejar a compra sem pagar juros. No Consórcio Nacional MI6, você pode adquirir imóveis, veículos, equipamentos ou eletroeletrônicos com parcelas acessíveis e flexibilidade para ofertar lances e antecipar a contemplação.',
  },
];

// Grupo ativo de motos: parâmetros vêm do espelho da tabela verdade
// (src/dados/grupos.json), que na fase 3 será alimentado pelo Excel do 365.
const grupoMotos = dados.grupos.find((g) => g.segmento === 'motos' && g.status === 'ativo')!;
const brlServidor = (v: number) =>
  'R$ ' + v.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const pct = (v: number) => (v * 100).toLocaleString('pt-BR');
const numServidor = (v: number) =>
  v.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

// Conta enxuta: a parcela e a taxa de administração convertida a taxa mensal.
// Tudo derivado do grupo no banco (grupos.json), sem números fixos no código.
const calcParcela = (g: typeof grupoMotos, credito: number) =>
  (credito * (1 + g.taxa_administracao + g.fundo_reserva)) / g.prazo_restante_meses;
const calcComSeguro = (g: typeof grupoMotos, credito: number) => {
  const base = credito * (1 + g.taxa_administracao + g.fundo_reserva);
  return base / g.prazo_restante_meses + base * g.seguro_prestamista_mes;
};
const taxaMensal = (g: typeof grupoMotos) => (g.taxa_administracao / g.prazo_restante_meses) * 100;

const simInicial = {
  credito: grupoMotos.credito_padrao.toLocaleString('pt-BR'),
  // Parcela exibida sempre com seguro prestamista (regra do produto: obrigatório).
  parcela: numServidor(calcComSeguro(grupoMotos, grupoMotos.credito_padrao)),
  taxaMensal: numServidor(taxaMensal(grupoMotos)),
};

// Ticket do hero "parcelas a partir de": menor parcela entre os grupos ativos,
// calculada do crédito mínimo de cada um. Quando novos grupos/segmentos forem
// conectados no banco, o ticket se atualiza sozinho.
const nomeSeg: Record<string, string> = {
  carros: 'Carros', pesados: 'Pesados', motos: 'Motos',
  imoveis: 'Imóveis', servicos: 'Serviços', eletro: 'Eletro',
};
const grupoDestaque = dados.grupos
  .filter((g) => g.status === 'ativo')
  .map((g) => ({ g, p: calcComSeguro(g, g.credito_min) }))
  .sort((a, b) => a.p - b.p)[0];
const ticket = grupoDestaque
  ? {
      rotulo: `${nomeSeg[grupoDestaque.g.segmento] ?? grupoDestaque.g.segmento} · grupos ativos`,
      valor: brlServidor(grupoDestaque.p),
      dia: Math.ceil(grupoDestaque.p / 30),
    }
  : null;

// Marca viva: guias de caligrafia no ângulo do talhe do logo (medido na
// barra vermelha: dx/dy = -0,3345), prolongadas para fora da tela.
const talhe = -0.3345;
const guiaInclinada = (xBase: number) => ({
  x1: xBase + (-1500 - 376) * talhe,
  y1: -1500,
  x2: xBase + (1900 - 376) * talhe,
  y2: 1900,
});
const guiasInclinadas = [60, 250, 640].map(guiaInclinada);
const guiaBarra = guiaInclinada(388);

// Cartões por segmento, navegáveis por setas. Cada segmento tem um tom
// próprio dentro da paleta da marca (azul, preto, vermelho da bandeira),
// sóbrio. A faixa de crédito (mínimo a máximo) vem do grupo ativo; segmento
// sem grupo aparece como "Em breve", sem inventar valor.
const temas: Record<string, [string, string]> = {
  carros: ['#0a2c66', '#02112e'],
  pesados: ['#2a2f3a', '#0b0e14'],
  motos: ['#06204e', '#4e0f1c'],
  imoveis: ['#103a72', '#05152f'],
  servicos: ['#1a2740', '#080d18'],
  eletro: ['#07265a', '#020a18'],
};
// Silhueta preenchida do bem de cada segmento, em perfil (viewBox 0 0 64 64):
// só o formato, sem cor. Serve de marca d'água no cartão e de ícone nos
// segmentos. Passaporte para serviços. Sóbrio, sem nada infantil.
const bens: Record<string, string> = {
  carros:
    '<path d="M2 42v-2c0-2 1-3 3-4l9-3 6-6c1-1 2-2 4-2h16c2 0 4 1 5 3l4 6 9 3c2 1 3 2 3 4v1z"/><circle cx="17" cy="43" r="5"/><circle cx="46" cy="43" r="5"/>',
  pesados:
    '<path d="M3 18h30v24H3z"/><path d="M33 27h12l8 8v7H33z"/><circle cx="13" cy="44" r="5.5"/><circle cx="45" cy="44" r="5.5"/>',
  motos:
    '<circle cx="15" cy="43" r="9"/><circle cx="49" cy="43" r="9"/><path d="M15 43l7-11q1-1 3-1h9l4-4h8l-3 5-5 1 6 11-8-6H26l-4 5z"/>',
  imoveis:
    '<path d="M7 31 32 11l25 20h-5v21H12V31z"/><path d="M43 16h4v7l-4-3z"/>',
  servicos:
    '<path fill-rule="evenodd" d="M14 11a3 3 0 0 1 3-3h27a3 3 0 0 1 3 3v42a3 3 0 0 1-3 3H17a3 3 0 0 1-3-3zm19 3a9 9 0 1 0 0 18 9 9 0 1 0 0-18zm0 3a6 6 0 1 1 0 12 6 6 0 1 1 0-12zM24 44h18v2.6H24zM24 49h12v2.4H24z"/>',
  eletro:
    '<path d="M7 14h50a2 2 0 0 1 2 2v23a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V16a2 2 0 0 1 2-2z"/><path d="M26 43h12l2 7H24z"/>',
};
const cartoes = segmentos.map((s) => {
  const g = dados.grupos.find((x) => x.segmento === s.id && x.status === 'ativo');
  const [c1, c2] = temas[s.id] ?? ['#012169', '#01112f'];
  // O cartão materializa o bem: "Sua moto", "Seu imóvel". Posse por segmento.
  const posses: Record<string, string> = {
    carros: 'Seu carro',
    pesados: 'Seu caminhão',
    motos: 'Sua moto',
    imoveis: 'Seu imóvel',
    servicos: 'Seu serviço',
    eletro: 'Seu eletro',
  };
  return {
    seg: s.id,
    nome: s.nome.replace('Consórcio de ', ''),
    posse: posses[s.id] ?? 'Seu bem',
    valor: g
      ? `R$ ${g.credito_min.toLocaleString('pt-BR')} a ${g.credito_max.toLocaleString('pt-BR')}`
      : 'Em breve',
    ativo: !!g,
    c1,
    c2,
    bem: bens[s.id] ?? '',
  };
});
const idxInicial = Math.max(0, cartoes.findIndex((c) => c.ativo));
const cartaoInicial = cartoes[idxInicial] ?? cartoes[0];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Conceito B, Carta materializada | Play MI6</title>
    <meta name="description" content="Protótipo da FASE 2: a carta de crédito materializada como cartão, poder de compra à vista." />
  </head>
  <body>
    <div class="veu" role="dialog" aria-label="Boas-vindas MI6">
      <button type="button" class="veu-pano veu-pano-cliente" data-perfil="cliente">
        <span class="veu-pano-rotulo">Já sou cliente</span>
        <span class="veu-pano-sub">boletos, lances e contemplação</span>
      </button>
      <button type="button" class="veu-pano veu-pano-novo" data-perfil="novo">
        <span class="veu-pano-rotulo">Ainda não sou</span>
        <span class="veu-pano-sub">quero simular meu plano</span>
      </button>
      <div class="veu-centro" aria-hidden="true">
        <span class="veu-linha"></span>
        <div class="veu-miolo">
          <img class="veu-logo" src="/imgs/logo-mi6-branco.png" alt="" width="219" height="47" />
          <p class="veu-pergunta">Como podemos te receber hoje?</p>
        </div>
      </div>
      <button type="button" class="veu-pular" data-perfil="">Entrar sem escolher</button>
    </div>
    <div class="grao" aria-hidden="true"></div>

    <header class="topo">
      <a class="topo-marca" href="/play/conceito-b/">
        <img src="/imgs/logo-mi6.png" alt="MI6 Consórcio Nacional" width="219" height="47" />
      </a>
      <div class="topo-acessos">
        <a class="acesso acesso-cliente" href="https://mi6.evertecinc.com.br/autoatendimento">
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="3.5"/><path d="M5 20c1-3.6 3.7-5.5 7-5.5s6 1.9 7 5.5"/></svg>
          <span>Sou cliente</span>
        </a>
        <a class="topo-cta" href="#contato">Simular</a>
      </div>
    </header>

    <main>
      <section class="hero" id="inicio">
        <p class="hero-coord" aria-hidden="true">30°02′S 51°13′W · PORTO ALEGRE · BRASIL</p>

        <div class="hero-grade">
          <div class="hero-conteudo">
            <p class="hero-kicker"><span id="scramble">O Melhor Investimento:</span></p>
            <h1 id="titulo">
              <span class="linha">6 caminhos para</span>
              <span class="linha">transformar <em>sonhos</em></span>
              <span class="linha">em conquistas</span>
            </h1>
            <p class="hero-frase" data-intro>Você está perto de realizar o seu projeto de vida</p>
            <div class="hero-acoes" data-intro>
              <a class="cta so-novo" href="#contato">Simule agora</a>
              <a class="cta so-cliente" href="https://mi6.evertecinc.com.br/autoatendimento">Área do Cliente</a>
              <button type="button" class="link-claro sub so-novo" data-folha="funciona">O que é consórcio?</button>
              <button type="button" class="link-claro sub so-cliente" data-folha="contemplacao">Fui contemplado, e agora?</button>
            </div>
            <p class="hero-prova" data-intro>
              <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M10 2.4l6 2.2v4.5c0 4.2-2.6 7-6 8.4-3.4-1.4-6-4.2-6-8.4V4.6z"/><path d="M7.2 10.1l2 2 3.6-3.8"/></svg>
              Administradora autorizada e fiscalizada pelo Banco Central do Brasil
            </p>
          </div>

          <div class="hero-visual">
            <div class="cartao-palco" data-intro>
              <button type="button" class="cartao-seta" id="cartao-prev" aria-label="Segmento anterior">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 5 8 12l7 7"/></svg>
              </button>
              <div class="cartao-carrossel" id="cartao-carrossel" role="group" aria-roledescription="carrossel de cartões" aria-label="Cartas de crédito por segmento">
                <ul class="cartao-pista" id="cartao-pista">
                  {
                    cartoes.map((c, i) => (
                      <li class="cartao-slot" data-i={i}>
                        <a class="cartao" href="#contato" style={`--c1:${c.c1};--c2:${c.c2}`} aria-label={`Simular ${c.nome}`}>
                          <span class="cartao-brilho" aria-hidden="true"></span>
                          <svg class="cartao-bem" viewBox="0 0 64 64" aria-hidden="true" set:html={c.bem} />
                          <div class="cartao-topo">
                            <img class="cartao-logo" src="/imgs/logo-mi6-branco.png" alt="MI6 Consórcio Nacional" width="219" height="47" />
                            <span class="cartao-spin" aria-hidden="true" />
                          </div>
                          <div class="cartao-corpo">
                            <p class="cartao-posse">{c.ativo ? `${c.posse} de` : c.posse}</p>
                            <p class="cartao-valor">{c.valor}</p>
                          </div>
                          <p class="cartao-legenda">Ao ser contemplado, você paga à vista com a carta de crédito.</p>
                        </a>
                      </li>
                    ))
                  }
                </ul>
              </div>
              <button type="button" class="cartao-seta" id="cartao-next" aria-label="Próximo segmento">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 5 7 7-7 7"/></svg>
              </button>
            </div>
            <p class="cartao-dica" aria-hidden="true">Navegue pelos segmentos e toque para simular</p>
            <p class="cartao-nota" data-intro>Crédito liberado ao ser contemplado. Use lance, inclusive o embutido, para antecipar.</p>
            <script type="application/json" id="cartoes-dados" set:html={JSON.stringify(cartoes)}></script>
          </div>
        </div>

        <p class="hero-scroll" aria-hidden="true">role</p>
      </section>

      <section class="credibilidade" aria-label="Credenciais institucionais">
        <div class="cred-abac">
          <img src="/imgs/abac.svg" alt="ABAC" width="127" height="41" />
          <p>Filiada à ABAC, Associação Brasileira de Administradoras de Consórcios</p>
        </div>
        <span class="cred-divisa" aria-hidden="true"></span>
        <div class="cred-bacen">
          <p class="cred-frase">Autorizada pelo Banco Central do Brasil</p>
          <p class="cred-oficio">Ofício nº 33.288/2024</p>
        </div>
      </section>

      <div class="marquee" aria-hidden="true">
        <div class="marquee-faixa">
          <span>Lei nº 11.795/2008 · SAC 0800 000 5228 · Ouvidoria 0800 000 5267 · Atendimento em todo o Brasil · </span><span>Lei nº 11.795/2008 · SAC 0800 000 5228 · Ouvidoria 0800 000 5267 · Atendimento em todo o Brasil · </span>
        </div>
      </div>

      <section class="jornada" id="solucoes">
        <header class="jornada-cabeca">
          <p class="indice" data-reveal>SIMPLES ASSIM</p>
          <h2 data-reveal>Da sua escolha à <em>carta de crédito</em></h2>
          <p data-reveal>
            Sua parte é mínima: escolher e pagar. O resto acontece sozinho,
            até a carta de crédito chegar na sua mão.
          </p>
        </header>

        <ol class="trilha">
          <span class="trilha-fio" aria-hidden="true"><i></i></span>

          <li class="estacao estacao-inicio" data-estacao>
            <span class="estacao-marco" aria-hidden="true"></span>
            <span class="estacao-quem">Você escolhe</span>
            <h3>O seu caminho</h3>
            <div class="estacao-segs" id="jornada-segs" role="group" aria-label="Segmentos">
              {
                segmentos.map((s) => (
                  <button type="button" data-segmento={s.id} aria-pressed={s.id === cartaoInicial.seg ? 'true' : 'false'}>
                    <svg class="seg-icone" viewBox="0 0 64 64" aria-hidden="true" set:html={bens[s.id] ?? ''} />
                    <span>{s.nome.replace('Consórcio de ', '')}</span>
                  </button>
                ))
              }
            </div>
          </li>

          <li class="estacao" data-estacao>
            <span class="estacao-marco" aria-hidden="true"></span>
            <span class="estacao-quem">Você paga</span>
            <h3>As parcelas</h3>
            <p>Parcelas que cabem no bolso, sem entrada e sem juros. Só isso da sua parte.</p>
          </li>

          <li class="estacao estacao-auto" data-estacao>
            <span class="estacao-marco" aria-hidden="true"></span>
            <span class="estacao-quem">Acontece sozinho</span>
            <h3>A contemplação</h3>
            <p>Todo mês você concorre na assembleia, automaticamente. Quer adiantar? Dê um lance, ou o embutido, usando parte do próprio crédito, sem tirar do bolso.</p>
          </li>

          <li class="estacao estacao-fim" data-estacao>
            <span class="estacao-marco estacao-marco-fim" aria-hidden="true"></span>
            <span class="estacao-quem">Você conquista</span>
            <h3>Sua carta de crédito</h3>
            <a class="jornada-cartao" id="jornada-cartao" href="#contato" style={`--c1:${cartaoInicial.c1};--c2:${cartaoInicial.c2}`} aria-label={`Simular ${cartaoInicial.nome}`}>
              <span class="jornada-cartao-rotulo">Carta de Crédito</span>
              <span class="jornada-cartao-valor" id="jornada-valor">{cartaoInicial.valor}</span>
              <span class="jornada-cartao-tag">Poder de compra à vista · <strong id="jornada-seg">{cartaoInicial.nome}</strong></span>
            </a>
          </li>
        </ol>
      </section>

      <section class="contato" id="contato">
        <svg class="contato-geo" aria-hidden="true" viewBox="0 0 1440 600" preserveAspectRatio="xMidYMid slice">
          <g class="geo-fim-claras" stroke="rgba(255,255,255,0.14)" stroke-width="1">
            <line x1="0" y1="0" x2="1440" y2="600"></line>
            <line x1="1440" y1="0" x2="0" y2="600"></line>
          </g>
          <g class="geo-fim-navy" stroke="rgba(1,33,105,0.28)" stroke-width="1">
            <line x1="80" y1="0" x2="1520" y2="600"></line>
            <line x1="1360" y1="0" x2="-80" y2="600"></line>
          </g>
        </svg>
        <div class="sim-grade">
          <header class="sim-cabeca">
            <p class="sim-kicker" data-reveal>Último passo da jornada</p>
            <h2 data-reveal>Sua conquista <em>começa</em> aqui</h2>
            <p data-reveal>Escolha, veja a parcela, fale com um consultor.</p>
          </header>

          <form
            class="sim-card"
            aria-label="Simulação e contato"
            data-prazo={grupoMotos.prazo_restante_meses}
            data-txadm={grupoMotos.taxa_administracao}
            data-fres={grupoMotos.fundo_reserva}
            data-seguro={grupoMotos.seguro_prestamista_mes}
            data-credito-padrao={grupoMotos.credito_padrao}
            data-grupo={grupoMotos.grupo}
            data-dia={grupoMotos.dia_assembleia}
          >
            <div class="sim-corpo" id="sim-corpo">
              <p class="sim-passo">01 · O que você vai conquistar hoje?</p>
              <div class="chips" id="sim-chips">
                {
                  segmentos.map((s) => (
                    <button
                      type="button"
