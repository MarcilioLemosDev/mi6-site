---
// Por ora, a entrada do site cai direto no conceito B (sem telas internas
// de FASE 2). A e C seguem acessíveis pelas URLs diretas, sem link.
const destino = '/play/conceito-b/';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0; url=${destino}`} />
    <link rel="canonical" href={destino} />
    <title>MI6 Consórcio Nacional</title>
    <script is:inline>window.location.replace('/play/conceito-b/');</script>
  </head>
  <body>
    <p>Redirecionando para o site, <a href={destino}>entrar agora</a>.</p>
  </body>
</html>
