---
import '@fontsource/instrument-serif';
import '@fontsource-variable/archivo';
import '@fontsource/ibm-plex-mono';
import Analytics from '@vercel/analytics/astro';

// Página 404 na identidade MI6. O Astro gera 404.html e a Vercel a serve
// automaticamente para qualquer rota inexistente (ex.: URLs antigas que o
// Google ainda tem indexadas e não foram cobertas por redirecionamento).
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>Página não encontrada · MI6 Consórcio Nacional</title>
    <meta name="description" content="A página que você procura não existe ou mudou de endereço." />
  </head>
  <body>
    <main class="palco">
      <a class="topo-logo" href="/" aria-label="MI6 Consórcio Nacional">
        <img src="/imgs/logo-mi6-branco.png" alt="MI6 Consórcio Nacional" width="219" height="47" />
      </a>

      <p class="codigo">Erro 404</p>
      <h1>Esta página mudou de lugar</h1>
      <p class="lead">
        O endereço que você abriu não existe mais no novo site da MI6. Nada se
        perdeu, é só seguir por aqui.
      </p>

      <a class="cta" href="/">
        Ir para a página inicial
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </a>

      <nav class="atalhos" aria-label="Atalhos">
        <a href="/#contato">Simular consórcio</a>
        <a href="/area-do-cliente/">Área do cliente</a>
      </nav>
    </main>

    <p class="coord" aria-hidden="true">30°02′S 51°13′W · PORTO ALEGRE · BRASIL</p>
    <Analytics />
  </body>
</html>

<style>
  :root {
    --navy: #012169;
    --red: #c8102e;
    --branco: #ffffff;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    min-height: 100svh;
    color: var(--branco);
    font-family: 'Archivo Variable', -apple-system, 'Segoe UI', Arial, sans-serif;
    line-height: 1.6;
    display: grid;
    place-items: center;
    padding: 2rem 1.3rem;
    position: relative;
    overflow-x: hidden;
    background:
      repeating-linear-gradient(0deg, transparent 0 31px, rgba(130, 175, 255, 0.06) 31px 32px),
      repeating-linear-gradient(90deg, transparent 0 31px, rgba(130, 175, 255, 0.06) 31px 32px),
      radial-gradient(120% 80% at 50% 0%, rgba(2, 33, 105, 0.95), rgba(1, 16, 47, 1) 72%);
  }
  .palco { max-width: 40rem; text-align: center; }
  .topo-logo img { height: 2rem; width: auto; margin: 0 auto 2.5rem; display: block; }
  .codigo {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #ff8a98;
    margin: 0 0 0.6rem;
  }
  h1 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-weight: 400;
    font-size: clamp(2.3rem, 6vw, 3.4rem);
    line-height: 1.05;
    margin: 0 0 0.9rem;
  }
  .lead {
    margin: 0 auto 2rem;
    max-width: 30rem;
    color: rgba(255, 255, 255, 0.78);
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--red);
    color: var(--branco);
    text-decoration: none;
    font-weight: 700;
    padding: 0.85rem 1.5rem;
    border-radius: 12px;
    transition: background 0.2s ease;
  }
  .cta svg {
    width: 1.2rem; height: 1.2rem;
    fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
    transition: transform 0.2s ease;
  }
  .cta:hover { background: #e21236; }
  .cta:hover svg { transform: translateX(3px); }
  .atalhos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem 1.6rem;
    margin-top: 2.4rem;
  }
  .atalhos a {
    color: rgba(255, 255, 255, 0.66);
    text-decoration: none;
    font-size: 0.9rem;
    border-bottom: 1px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .atalhos a:hover { color: #fff; border-color: rgba(255, 255, 255, 0.4); }
  .coord {
    position: fixed;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.3);
  }
  @media (max-width: 34rem) {
    .coord { display: none; }
  }
</style>
